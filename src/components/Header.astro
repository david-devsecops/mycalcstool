---
const currentPath = Astro.url.pathname;

const navItems = [
  { path: '/loan', label: '대출 계산기', category: '금융' },
  { path: '/salary', label: '연봉 계산기', category: '금융' },
  { path: '/tax-refund', label: '연말정산', category: '금융' },
  { path: '/compound', label: '복리 계산기', category: '금융' },
  { path: '/severance', label: '퇴직금', category: '금융' },
  { path: '/bmi', label: 'BMI', category: '건강' },
  { path: '/calorie', label: '칼로리', category: '건강' },
  { path: '/tdee', label: '기초대사량', category: '건강' },
  { path: '/due-date', label: '출산예정일', category: '생활' },
  { path: '/dday', label: 'D-day', category: '생활' },
];
---

<header class="bg-white border-b border-gray-200 sticky top-0 z-50 shadow-sm">
  <div class="max-w-4xl mx-auto px-4">
    <div class="flex items-center justify-between h-16">
      <!-- 로고 -->
      <a href="/" class="flex items-center gap-2 font-bold text-xl text-primary-700 hover:text-primary-600 transition-colors" aria-label="mycalcstool 홈으로">
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <rect width="28" height="28" rx="6" fill="#2563EB"/>
          <rect x="6" y="6" width="7" height="7" rx="1.5" fill="white"/>
          <rect x="15" y="6" width="7" height="7" rx="1.5" fill="white"/>
          <rect x="6" y="15" width="7" height="7" rx="1.5" fill="white"/>
          <rect x="15" y="15" width="7" height="7" rx="1.5" fill="#93C5FD"/>
        </svg>
        <span>mycalcstool</span>
      </a>

      <!-- 데스크톱 네비게이션 -->
      <nav class="hidden md:flex items-center gap-1" aria-label="주요 계산기">
        {navItems.slice(0, 6).map(item => (
          <a
            href={item.path}
            class={`px-3 py-2 rounded-lg text-sm font-medium transition-colors ${
              currentPath === item.path
                ? 'bg-primary-50 text-primary-700'
                : 'text-gray-600 hover:text-primary-600 hover:bg-gray-50'
            }`}
            aria-current={currentPath === item.path ? 'page' : undefined}
          >
            {item.label}
          </a>
        ))}
        <a href="/" class="px-3 py-2 text-sm text-gray-500 hover:text-primary-600 transition-colors">
          더보기
        </a>
      </nav>

      <!-- 모바일 햄버거 버튼 -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 rounded-lg text-gray-600 hover:bg-gray-100 transition-colors"
        aria-label="메뉴 열기"
        aria-expanded="false"
        aria-controls="mobile-menu"
        type="button"
      >
        <svg id="menu-open-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
        <svg id="menu-close-icon" class="hidden" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- 모바일 메뉴 -->
  <nav id="mobile-menu" class="hidden md:hidden border-t border-gray-100 bg-white" aria-label="모바일 네비게이션">
    <div class="max-w-4xl mx-auto px-4 py-4">
      <div class="grid grid-cols-2 gap-2">
        {['금융', '건강', '생활'].map(category => (
          <div class="col-span-2">
            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">{category}</p>
            <div class="grid grid-cols-2 gap-2">
              {navItems.filter(item => item.category === category).map(item => (
                <a
                  href={item.path}
                  class={`px-3 py-2.5 rounded-lg text-sm font-medium transition-colors ${
                    currentPath === item.path
                      ? 'bg-primary-50 text-primary-700'
                      : 'text-gray-700 hover:bg-gray-50 hover:text-primary-600'
                  }`}
                >
                  {item.label}
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </nav>
</header>

<script>
  // 모바일 메뉴 토글 (XSS 안전: DOM 조작만)
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const openIcon = document.getElementById('menu-open-icon');
  const closeIcon = document.getElementById('menu-close-icon');

  if (btn && menu && openIcon && closeIcon) {
    btn.addEventListener('click', () => {
      const isOpen = !menu.classList.contains('hidden');
      menu.classList.toggle('hidden');
      openIcon.classList.toggle('hidden');
      closeIcon.classList.toggle('hidden');
      btn.setAttribute('aria-expanded', String(!isOpen));
    });
  }
</script>

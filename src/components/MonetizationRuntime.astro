---
import { adProvider } from '../data/site-meta';

const loadEzoicRuntime = adProvider === 'ezoic';
---

{loadEzoicRuntime && (
  <script is:inline>
    window.mycalcEzoic = window.mycalcEzoic || {
      showAds: (...placementIds) => {
        window.ezstandalone = window.ezstandalone || {};
        ezstandalone.cmd = ezstandalone.cmd || [];
        ezstandalone.cmd.push(() => {
          if (placementIds.length > 0) {
            ezstandalone.showAds(...placementIds);
            return;
          }

          ezstandalone.showAds();
        });
      },
      destroyPlaceholders: (...placementIds) => {
        window.ezstandalone = window.ezstandalone || {};
        ezstandalone.cmd = ezstandalone.cmd || [];
        ezstandalone.cmd.push(() => {
          if (placementIds.length > 0) {
            ezstandalone.destroyPlaceholders(...placementIds);
            return;
          }

          ezstandalone.destroyAll();
        });
      },
    };

    document.addEventListener('DOMContentLoaded', () => {
      const placementIds = Array.from(
        document.querySelectorAll('[id^="ezoic-pub-ad-placeholder-"]')
      )
        .map((element) => Number(element.id.replace('ezoic-pub-ad-placeholder-', '')))
        .filter((value) => Number.isFinite(value));

      if (placementIds.length > 0) {
        window.mycalcEzoic.showAds(...placementIds);
      }
    });
  </script>
)}

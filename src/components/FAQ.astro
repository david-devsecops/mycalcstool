---
interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  items: FAQItem[];
  title?: string;
}

const { items, title = '자주 묻는 질문' } = Astro.props;

// FAQPage JSON-LD 구조화 데이터 생성
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: items.map(item => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
---

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

<section class="card mt-6" aria-labelledby="faq-title">
  <h2 class="section-title" id="faq-title">
    <span aria-hidden="true">❓</span>
    {title}
  </h2>

  <div class="space-y-3" role="list">
    {items.map((item, index) => (
      <div class="faq-item" role="listitem">
        <button
          class="faq-question"
          aria-expanded="false"
          aria-controls={`faq-answer-${index}`}
          id={`faq-question-${index}`}
          type="button"
        >
          <span>{item.question}</span>
          <span class="faq-icon text-primary-600 font-bold text-xl leading-none" aria-hidden="true">+</span>
        </button>
        <div
          class="faq-answer"
          id={`faq-answer-${index}`}
          role="region"
          aria-labelledby={`faq-question-${index}`}
        >
          {item.answer}
        </div>
      </div>
    ))}
  </div>
</section>

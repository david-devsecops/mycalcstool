---
import { adProvider as defaultAdProvider, adsenseClient } from '../data/site-meta';

interface Props {
  slot: 'top' | 'result' | 'content' | 'mid' | 'mid2';
  provider?: 'auto' | 'ezoic' | 'adsense';
  format?: 'auto' | 'rectangle' | 'horizontal';
  label?: string;
}

const { slot, provider = 'auto', format = 'auto', label = '광고' } = Astro.props;

const placementIds: Record<Props['slot'], string | undefined> = {
  top: import.meta.env.PUBLIC_EZOIC_PLACEHOLDER_TOP,
  result: import.meta.env.PUBLIC_EZOIC_PLACEHOLDER_RESULT,
  content: import.meta.env.PUBLIC_EZOIC_PLACEHOLDER_CONTENT,
  mid: import.meta.env.PUBLIC_EZOIC_PLACEHOLDER_MID,
  mid2: import.meta.env.PUBLIC_EZOIC_PLACEHOLDER_MID2,
};

const adsenseSlots: Record<Props['slot'], string | undefined> = {
  top: import.meta.env.PUBLIC_ADSENSE_SLOT_TOP,
  result: import.meta.env.PUBLIC_ADSENSE_SLOT_RESULT,
  content: import.meta.env.PUBLIC_ADSENSE_SLOT_CONTENT,
  mid: import.meta.env.PUBLIC_ADSENSE_SLOT_MID,
  mid2: import.meta.env.PUBLIC_ADSENSE_SLOT_MID2,
};
const ezoicPlacementId = placementIds[slot]?.trim();
const adsenseSlotId = adsenseSlots[slot]?.trim();

const requestedProvider = provider === 'auto' ? defaultAdProvider : provider;

const resolvedProvider =
  requestedProvider === 'ezoic'
    ? ezoicPlacementId
      ? 'ezoic'
      : 'none'
    : requestedProvider === 'adsense'
      ? adsenseClient && adsenseSlotId
        ? 'adsense'
        : 'none'
      : 'none';

const placeholderId =
  resolvedProvider === 'ezoic' && ezoicPlacementId
    ? `ezoic-pub-ad-placeholder-${ezoicPlacementId}`
    : undefined;
---

{placeholderId && (
  <aside class="ad-slot my-4" aria-label={label} data-ezoic-slot={slot} role="complementary">
    <div id={placeholderId}></div>
  </aside>
)}

{resolvedProvider === 'adsense' && adsenseClient && adsenseSlotId && (
  <aside class="ad-slot my-4" aria-label={label} data-adsense-slot={slot} role="complementary">
    <ins
      class="adsbygoogle"
      style="display:block"
      data-ad-client={adsenseClient}
      data-ad-slot={adsenseSlotId}
      data-ad-format={format}
      data-full-width-responsive="true"
    ></ins>
    <script is:inline>
      (adsbygoogle = window.adsbygoogle || []).push({});
    </script>
  </aside>
)}

---
interface Props {
  isEnglish?: boolean;
}
const { isEnglish = false } = Astro.props;
---

<div id="visitor-counter" class="flex items-center justify-center gap-4 text-xs text-gray-400 mt-3">
  <span class="flex items-center gap-1.5">
    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
      <circle cx="9" cy="7" r="4"/>
      <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
      <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
    </svg>
    <span>
      {isEnglish ? "Today's visitors:" : "오늘 방문자:"}
      <strong id="daily-count" class="text-gray-500 ml-0.5">—</strong>
    </span>
  </span>
  <span class="text-gray-300" aria-hidden="true">|</span>
  <span class="flex items-center gap-1.5">
    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
    </svg>
    <span>
      {isEnglish ? 'Total:' : '누적:'}
      <strong id="total-count" class="text-gray-500 ml-0.5">—</strong>
    </span>
  </span>
</div>

<script is:inline>
(function () {
  var NS = 'mycalcstool-com';
  var BASE = 'https://api.counterapi.dev/v1';
  var today = new Date().toISOString().slice(0, 10).replace(/-/g, '');
  var dailyKey = 'daily-' + today;
  var totalKey = 'total';
  var SESSION_KEY = 'mct_visited';

  var counterEl = document.getElementById('visitor-counter');
  var dailyEl = document.getElementById('daily-count');
  var totalEl = document.getElementById('total-count');
  if (!counterEl || !dailyEl || !totalEl) return;

  var alreadyCounted = sessionStorage.getItem(SESSION_KEY) === today;
  var suffix = alreadyCounted ? '/' : '/up/';

  function fmt(n) {
    return (n || 0).toLocaleString();
  }

  function fetchWithTimeout(url, ms) {
    return new Promise(function (resolve, reject) {
      var timer = setTimeout(function () { reject(new Error('timeout')); }, ms);
      fetch(url)
        .then(function (r) { clearTimeout(timer); resolve(r); })
        .catch(function (e) { clearTimeout(timer); reject(e); });
    });
  }

  Promise.all([
    fetchWithTimeout(BASE + '/' + NS + '/' + dailyKey + suffix, 5000),
    fetchWithTimeout(BASE + '/' + NS + '/' + totalKey + suffix, 5000),
  ])
    .then(function (responses) {
      return Promise.all(responses.map(function (r) { return r.json(); }));
    })
    .then(function (data) {
      if (!alreadyCounted) sessionStorage.setItem(SESSION_KEY, today);
      dailyEl.textContent = fmt(data[0].count !== undefined ? data[0].count : data[0].value);
      totalEl.textContent = fmt(data[1].count !== undefined ? data[1].count : data[1].value);
    })
    .catch(function () {
      counterEl.style.display = 'none';
    });
})();
</script>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import AdSlot from '../components/AdSlot.astro';
import siteConfig from '../data/site-config.json';
import { koFinanceGuides } from '../data/ko-finance-guides';
import { siteMeta } from '../data/site-meta';

const title = '무료 온라인 계산기 모음 - 대출, 연봉, BMI, 복리 계산';
const description = '대출 이자, 연봉 실수령액, BMI, 복리, 퇴직금, 칼로리 등 생활에 꼭 필요한 계산기를 무료로 제공합니다. 빠르고 정확한 계산으로 현명한 결정을 도와드립니다.';
const keywords = '무료계산기, 대출계산기, 연봉계산기, BMI계산기, 복리계산기, 퇴직금계산기, 칼로리계산기, 연말정산계산기';

const categories = ['금융', '건강', '생활'];
const categoryColors: Record<string, string> = {
  '금융': 'bg-blue-50 text-blue-700 border-blue-200',
  '건강': 'bg-green-50 text-green-700 border-green-200',
  '생활': 'bg-purple-50 text-purple-700 border-purple-200',
};

const featuredFinance = siteConfig.calculators
  .filter((calculator) => calculator.category === '금융')
  .sort((left, right) => right.priority - left.priority)
  .slice(0, 5);

const featuredGuidePosts = koFinanceGuides.slice(0, 6);

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'mycalcstool',
  url: 'https://mycalcstool.com',
  description,
  potentialAction: {
    '@type': 'SearchAction',
    target: 'https://mycalcstool.com/?q={search_term_string}',
    'query-input': 'required name=search_term_string',
  },
};
---

<BaseLayout title={title} description={description} keywords={keywords} jsonLd={websiteSchema} hreflangEn="/en/">
  <!-- 언어 자동 리다이렉트 (클라이언트 사이드, SEO 무영향) -->
  <script>
    (function () {
      // 크롤러는 리다이렉트하지 않음
      if (/bot|crawler|spider|googlebot|bingbot|slurp|duckduckbot|baidu|yandex/i.test(navigator.userAgent)) return;
      // 이미 /en/ 경로면 리다이렉트 불필요
      if (location.pathname.startsWith('/en')) return;
      // 사용자가 수동으로 한국어를 선택한 경우 리다이렉트하지 않음
      if (localStorage.getItem('preferred-lang') === 'ko') return;
      // 브라우저 언어가 한국어가 아니면 /en/으로 이동
      const lang = navigator.language || '';
      if (!lang.startsWith('ko')) {
        location.replace('/en/');
      }
    })();
  </script>

  <!-- 히어로 섹션 -->
  <section class="text-center mb-10">
    <h1 class="text-3xl md:text-4xl font-bold text-gray-800 mb-4">
      무료 온라인 계산기 모음
    </h1>
    <p class="text-lg text-gray-600 max-w-2xl mx-auto leading-relaxed">
      대출, 연봉, 세금처럼 결정에 바로 쓰는 금융 계산기를 우선 강화하고<br class="hidden md:block" />
      건강·생활 계산기는 보조 도구로 함께 제공합니다.
    </p>
  </section>

  <!-- 상단 광고 -->
  <AdSlot slot="top" format="horizontal" />

  <section class="mb-8" aria-labelledby="featured-finance">
    <div class="flex items-center justify-between gap-3 mb-4 flex-wrap">
      <h2 class="text-xl font-bold text-gray-700" id="featured-finance">우선 추천하는 금융 계산기</h2>
      <a href="/methodology" class="text-sm font-semibold text-primary-600 hover:text-primary-700 transition-colors">계산 기준 보기 →</a>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {featuredFinance.map(calc => (
        <a
          href={calc.path}
          class="card hover:shadow-md hover:border-primary-200 transition-all duration-200 group cursor-pointer no-underline"
          aria-label={`${calc.name} 바로가기`}
        >
          <div class="flex items-start gap-3">
            <span class="text-3xl" role="img" aria-label={calc.name}>{calc.icon}</span>
            <div class="flex-1 min-w-0">
              <div class="mb-2">
                <span class={`text-xs px-2.5 py-1 rounded-full border font-medium ${categoryColors[calc.category]}`}>
                  {calc.category}
                </span>
              </div>
              <h3 class="font-semibold text-gray-800 group-hover:text-primary-600 transition-colors">
                {calc.name}
              </h3>
              <p class="text-sm text-gray-500 mt-1 leading-snug">
                {calc.description}
              </p>
            </div>
          </div>
          <div class="mt-3 text-sm font-medium text-primary-600 group-hover:text-primary-700 flex items-center gap-1">
            계산하기
            <span aria-hidden="true">→</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="mb-8">
    <div class="flex items-center justify-between gap-3 mb-4 flex-wrap">
      <h2 class="text-xl font-bold text-gray-700">금융 가이드</h2>
      <a href="/blog/" class="text-sm font-semibold text-primary-600 hover:text-primary-700 transition-colors">전체 글 보기 →</a>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
      {featuredGuidePosts.map((post) => (
        <a href={post.href} class="card hover:shadow-md hover:border-primary-200 transition-all group no-underline">
          <div class="flex items-center gap-2 mb-2">
            <span class="text-xs font-semibold text-primary-600 bg-primary-50 px-2 py-0.5 rounded-full">{post.category}</span>
            <span class="text-xs text-gray-400">{post.readTime}</span>
          </div>
          <h3 class="font-semibold text-gray-800 group-hover:text-primary-600 transition-colors">{post.title}</h3>
          <p class="text-sm text-gray-500 mt-2 leading-relaxed">{post.description}</p>
        </a>
      ))}
    </div>

    <h2 class="text-xl font-bold text-gray-700 mb-4">보조 계산기</h2>
    <div class="space-y-8">
      {categories.filter((category) => category !== '금융').map(category => {
        const calcs = siteConfig.calculators.filter(c => c.category === category);
        return (
          <section aria-labelledby={`category-${category}`}>
            <h3 class="text-lg font-bold text-gray-700 mb-4 flex items-center gap-2" id={`category-${category}`}>
              <span class={`text-xs px-2.5 py-1 rounded-full border font-medium ${categoryColors[category]}`}>
                {category}
              </span>
            </h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
              {calcs.map(calc => (
                <a
                  href={calc.path}
                  class="card hover:shadow-md hover:border-primary-200 transition-all duration-200 group cursor-pointer no-underline"
                  aria-label={`${calc.name} 바로가기`}
                >
                  <div class="flex items-start gap-3">
                    <span class="text-3xl" role="img" aria-label={calc.name}>{calc.icon}</span>
                    <div class="flex-1 min-w-0">
                      <h4 class="font-semibold text-gray-800 group-hover:text-primary-600 transition-colors">
                        {calc.name}
                      </h4>
                      <p class="text-sm text-gray-500 mt-1 leading-snug">
                        {calc.description}
                      </p>
                    </div>
                  </div>
                  <div class="mt-3 text-sm font-medium text-primary-600 group-hover:text-primary-700 flex items-center gap-1">
                    계산하기
                    <span aria-hidden="true">→</span>
                  </div>
                </a>
              ))}
            </div>
          </section>
        );
      })}
    </div>
  </section>

  <!-- 사이트 소개 섹션 -->
  <section class="card bg-primary-50 border-primary-100 mt-8">
    <h2 class="text-lg font-bold text-primary-800 mb-3">mycalcstool 소개</h2>
    <p class="text-gray-700 leading-relaxed text-sm">
      {siteMeta.name}은 금융 계산기를 중심으로 운영하는 무료 온라인 계산기 서비스입니다.
      모든 계산은 브라우저에서 직접 처리되며, 계산 기준과 문의 경로는
      <a href="/methodology" class="font-semibold text-primary-700 hover:underline"> 계산 기준</a>,
      <a href="/blog/" class="font-semibold text-primary-700 hover:underline"> 금융 가이드</a>,
      <a href="/contact" class="font-semibold text-primary-700 hover:underline"> 문의하기</a> 페이지에서 확인할 수 있습니다.
    </p>
  </section>
</BaseLayout>

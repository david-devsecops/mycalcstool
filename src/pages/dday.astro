---
import BaseLayout from '../layouts/BaseLayout.astro';
import AdSlot from '../components/AdSlot.astro';
import FAQ from '../components/FAQ.astro';

const title = 'D-day 날짜 계산기 - 두 날짜 사이 일수 계산';
const description = '두 날짜 사이의 일수를 계산하고, 특정 날짜로부터 D-day를 확인하세요. 기념일, 시험, 여행 등 중요한 날까지 남은 일수를 계산합니다.';
const keywords = 'D-day 계산기, 날짜 계산기, 두 날짜 사이 일수, 기념일 계산기, 남은 날짜 계산, 디데이 계산기';

const faqItems = [
  {
    question: 'D-day는 어떻게 계산하나요?',
    answer: '목표일에서 오늘 날짜를 빼서 남은 일수를 계산합니다. 목표일이 미래이면 D-숫자(D-30 등), 오늘이면 D-Day, 과거이면 D+숫자(D+30 등)로 표시됩니다. 이 계산기는 시작일과 종료일을 모두 설정하여 기간도 계산할 수 있습니다.',
  },
  {
    question: '영업일 계산도 되나요?',
    answer: '현재 버전에서는 달력 기준 일수 계산을 제공합니다. 공휴일을 제외한 영업일 계산은 별도의 기능으로 추후 추가 예정입니다. 대략적인 영업일은 전체 일수 × 5/7로 추산할 수 있습니다.',
  },
  {
    question: '날짜 간격을 월 단위로도 볼 수 있나요?',
    answer: '네, 이 계산기는 일수, 주수, 월수, 년수를 함께 표시합니다. 예를 들어 100일은 약 3개월 9일, 약 14주 2일로 변환하여 보여줍니다.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'D-day 날짜 계산기',
  description,
  url: 'https://mycalcstool.com/dday',
  applicationCategory: 'UtilitiesApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'KRW' },
  inLanguage: 'ko',
};

// 미리 설정된 이벤트 목록
const presets = [
  { label: '🎓 수능 (2026.11.19)', date: '2026-11-19' },
  { label: '🎄 크리스마스 (2026.12.25)', date: '2026-12-25' },
  { label: '🎆 신년 (2027.01.01)', date: '2027-01-01' },
  { label: '🌸 어린이날 (2026.05.05)', date: '2026-05-05' },
];
---

<BaseLayout title={title} description={description} keywords={keywords} jsonLd={jsonLd} hreflangEn="/en/days-calculator">
  <div class="mb-6">
    <nav class="text-sm text-gray-500 mb-2" aria-label="breadcrumb">
      <ol class="flex items-center gap-1 list-none p-0">
        <li><a href="/" class="hover:text-primary-600 transition-colors">홈</a></li>
        <li aria-hidden="true" class="text-gray-300">/</li>
        <li class="text-gray-700 font-medium" aria-current="page">D-day 날짜 계산기</li>
      </ol>
    </nav>
    <h1 class="text-2xl md:text-3xl font-bold text-gray-800">📅 D-day 날짜 계산기</h1>
    <p class="text-gray-500 mt-2">두 날짜 사이의 일수 및 D-day를 계산하세요</p>
  </div>

  <AdSlot slot="top" format="horizontal" />

  <section class="card mb-6">
    <h2 class="section-title"><span aria-hidden="true">📝</span> 날짜 입력</h2>
    <div class="space-y-6">
      <!-- 빠른 선택 -->
      <div>
        <p class="text-sm font-semibold text-gray-700 mb-2">빠른 선택</p>
        <div class="grid grid-cols-2 gap-2">
          {presets.map(p => (
            <button class="preset-btn text-left px-3 py-2 text-sm border border-gray-200 rounded-lg hover:border-primary-400 hover:bg-primary-50 transition-colors text-gray-700" data-date={p.date} type="button">{p.label}</button>
          ))}
        </div>
      </div>

      <hr class="border-gray-100" />

      <!-- 시작일 -->
      <div>
        <label for="start-date" class="block text-sm font-semibold text-gray-700 mb-2">시작일 (기준일)</label>
        <input type="date" id="start-date" class="input-field" aria-label="시작일" />
        <p class="text-xs text-gray-400 mt-1">비워두면 오늘 날짜가 기준입니다</p>
      </div>
      <!-- 목표일 -->
      <div>
        <label for="target-date" class="block text-sm font-semibold text-gray-700 mb-2">목표일 / 종료일</label>
        <input type="date" id="target-date" class="input-field" aria-label="목표일" />
      </div>
      <!-- 이름 (선택) -->
      <div>
        <label for="event-name" class="block text-sm font-semibold text-gray-700 mb-2">이벤트 이름 <span class="text-gray-400 font-normal">(선택)</span></label>
        <input type="text" id="event-name" class="input-field" placeholder="예: 수능, 결혼기념일, 여행..." maxlength="50" />
      </div>
      <button id="calc-dday-btn" class="btn-primary" type="button">🔍 D-day 계산하기</button>
    </div>
  </section>

  <!-- 결과 -->
  <div id="dday-results" class="hidden" aria-live="polite">
    <section class="card mb-6">
      <h2 class="section-title"><span aria-hidden="true">📊</span> D-day 결과</h2>
      <div class="text-center py-8">
        <p class="text-sm text-gray-500 mb-2" id="event-name-display"></p>
        <p class="text-6xl font-bold text-primary-600 tabular-nums" id="dday-display">-</p>
        <p class="text-lg text-gray-600 mt-2" id="dday-date-display">-</p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
        {[
          { id: 'dday-days', label: '총 일수' },
          { id: 'dday-weeks', label: '주' },
          { id: 'dday-months', label: '개월' },
          { id: 'dday-years', label: '년' },
        ].map(item => (
          <div class="bg-gray-50 rounded-xl p-4 text-center">
            <p class="text-xs text-gray-500 mb-1">{item.label}</p>
            <p class="text-xl font-bold tabular-nums text-gray-700" id={item.id}>-</p>
          </div>
        ))}
      </div>
    </section>

    <!-- 추가 날짜 계산 -->
    <section class="card mb-6">
      <h2 class="section-title"><span aria-hidden="true">🔢</span> 특정 일수 후 날짜</h2>
      <div class="space-y-2">
        {[100, 200, 365, 500, 1000].map(days => (
          <div class="flex justify-between items-center py-2 border-b border-gray-100 last:border-0">
            <span class="text-sm text-gray-600">기준일로부터 {days}일 후</span>
            <span class="text-sm tabular-nums font-medium text-gray-700" id={`after-${days}`}>-</span>
          </div>
        ))}
      </div>
    </section>

    <AdSlot slot="result" format="rectangle" />
    <AdSlot slot="content" format="rectangle" />
  </div>

  <FAQ items={faqItems} />

  <section class="card mt-6">
    <h2 class="section-title"><span aria-hidden="true">🔗</span> 관련 계산기</h2>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
      {[
        { href: '/due-date', label: '👶 출산 예정일', desc: '출산 날짜 계산' },
        { href: '/calorie', label: '🍎 칼로리 계산기', desc: '음식 칼로리 계산' },
        { href: '/bmi', label: '⚖️ BMI 계산기', desc: '건강 체중 확인' },
      ].map(l => (
        <a href={l.href} class="p-3 border border-gray-200 rounded-lg hover:border-primary-300 hover:bg-primary-50 transition-colors group">
          <div class="font-medium text-sm text-gray-700 group-hover:text-primary-600">{l.label}</div>
          <div class="text-xs text-gray-400 mt-0.5">{l.desc}</div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<script>
function formatDate(d: Date): string {
  return `${d.getFullYear()}년 ${d.getMonth()+1}월 ${d.getDate()}일 (${['일','월','화','수','목','금','토'][d.getDay()]})`;
}
function addDays(d: Date, n: number): Date { const r = new Date(d); r.setDate(r.getDate()+n); return r; }

function calculate() {
  const targetEl = document.getElementById('target-date') as HTMLInputElement;
  const startEl = document.getElementById('start-date') as HTMLInputElement;
  const nameEl = document.getElementById('event-name') as HTMLInputElement;

  if (!targetEl?.value) { alert('목표일을 입력해주세요.'); return; }

  const targetDate = new Date(targetEl.value);
  const startDate = startEl?.value ? new Date(startEl.value) : new Date();
  startDate.setHours(0,0,0,0);
  targetDate.setHours(0,0,0,0);

  const diffMs = targetDate.getTime() - startDate.getTime();
  const diffDays = Math.round(diffMs / (1000 * 60 * 60 * 24));
  const absDays = Math.abs(diffDays);

  let ddayText = '';
  if (diffDays > 0) ddayText = `D-${diffDays}`;
  else if (diffDays === 0) ddayText = 'D-Day!';
  else ddayText = `D+${absDays}`;

  const setText = (id: string, val: string) => { const el = document.getElementById(id); if (el) el.textContent = val; };

  const eventName = (nameEl?.value || '').trim().substring(0, 50); // 입력 제한
  setText('event-name-display', eventName || '목표일까지');
  setText('dday-display', ddayText);
  setText('dday-date-display', formatDate(targetDate));
  setText('dday-days', absDays.toLocaleString('ko-KR') + '일');
  setText('dday-weeks', `${Math.floor(absDays/7)}주 ${absDays%7}일`);
  setText('dday-months', `${Math.floor(absDays/30)}개월 ${absDays%30}일`);
  setText('dday-years', `${Math.floor(absDays/365)}년 ${Math.floor((absDays%365)/30)}개월`);

  // N일 후 날짜
  [100, 200, 365, 500, 1000].forEach(n => {
    setText(`after-${n}`, formatDate(addDays(startDate, n)));
  });

  const results = document.getElementById('dday-results');
  if (results) { results.classList.remove('hidden'); results.scrollIntoView({ behavior: 'smooth', block: 'start' }); }
}

document.addEventListener('DOMContentLoaded', () => {
  // 오늘 기본값
  const startEl = document.getElementById('start-date') as HTMLInputElement;
  const targetEl = document.getElementById('target-date') as HTMLInputElement;
  const today = new Date();
  if (startEl) startEl.value = today.toISOString().split('T')[0];
  // 기본 목표: 100일 후
  const future = addDays(today, 100);
  if (targetEl) targetEl.value = future.toISOString().split('T')[0];

  // 빠른 선택
  document.querySelectorAll('.preset-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const date = (btn as HTMLElement).dataset.date;
      if (targetEl && date) { targetEl.value = date; calculate(); }
    });
  });

  document.getElementById('calc-dday-btn')?.addEventListener('click', calculate);
  calculate();
});
</script>

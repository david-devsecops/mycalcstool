---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdSlot from '../../components/AdSlot.astro';
import FAQ from '../../components/FAQ.astro';
import RelatedCalculators from '../../components/RelatedCalculators.astro';

const title = 'Age Calculator — How Old Am I? Calculate Your Exact Age';
const description = 'Calculate your exact age in years, months, days, hours, minutes, and seconds. Find out what day you were born and your next birthday.';
const keywords = 'age calculator, how old am I, calculate age from date of birth, exact age calculator';

const faqItems = [
  {
    question: 'How is age calculated exactly?',
    answer: 'Age is calculated by counting the difference in years, months, and days between your birth date and today (or a selected date). The calculator accounts for leap years and varying month lengths.',
  },
  {
    question: 'What day of the week was I born?',
    answer: 'Enter your birthdate above and the calculator will instantly tell you the exact day of the week you were born.',
  },
  {
    question: 'How many days until my next birthday?',
    answer: 'The calculator automatically computes your next birthday date and shows a countdown in days. It accounts for the current year and whether your birthday has already passed this year.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Age Calculator',
  description,
  url: 'https://mycalcstool.com/en/age-calculator',
  applicationCategory: 'UtilitiesApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  inLanguage: 'en',
};

const today = new Date().toISOString().split('T')[0];
---

<BaseLayout title={title} description={description} keywords={keywords} lang="en" jsonLd={jsonLd}>
  <div class="mb-6">
    <nav class="text-sm text-gray-500 mb-2" aria-label="breadcrumb">
      <ol class="flex items-center gap-1 list-none p-0">
        <li><a href="/en/" class="hover:text-primary-600 transition-colors">Home</a></li>
        <li aria-hidden="true" class="text-gray-300">/</li>
        <li class="text-gray-700 font-medium" aria-current="page">Age Calculator</li>
      </ol>
    </nav>
    <h1 class="text-2xl md:text-3xl font-bold text-gray-800">🎂 Age Calculator</h1>
    <p class="text-gray-500 mt-2">Find your exact age, born day, next birthday & zodiac sign</p>
  </div>

  <AdSlot slot="top" format="horizontal" />

  <section class="card mb-6">
    <h2 class="section-title"><span aria-hidden="true">📅</span> Enter Your Details</h2>
    <div class="space-y-4">
      <div>
        <label for="dob" class="block text-sm font-semibold text-gray-700 mb-1">Date of Birth</label>
        <input type="date" id="dob" class="input-field" max={today} />
      </div>
      <div>
        <label for="calc-date" class="block text-sm font-semibold text-gray-700 mb-1">Calculate as of</label>
        <input type="date" id="calc-date" class="input-field" value={today} />
      </div>
      <button id="calc-age-btn" class="btn-primary" type="button">Calculate Age</button>
    </div>
  </section>

  <div id="age-results" class="hidden" aria-live="polite">
    <section class="card mb-6">
      <h2 class="section-title"><span aria-hidden="true">🎉</span> Your Age</h2>
      <div class="text-center py-6">
        <p class="text-4xl font-bold text-primary-700" id="age-main">—</p>
        <p class="text-gray-500 mt-2" id="age-sub">years, months, days</p>
      </div>
      <div class="grid grid-cols-3 gap-3 mt-2">
        <div class="bg-gray-50 rounded-xl p-4 text-center">
          <p class="text-xs text-gray-500 mb-1">Total Days</p>
          <p class="text-lg font-bold tabular-nums text-gray-700" id="total-days">—</p>
        </div>
        <div class="bg-gray-50 rounded-xl p-4 text-center">
          <p class="text-xs text-gray-500 mb-1">Total Hours</p>
          <p class="text-lg font-bold tabular-nums text-gray-700" id="total-hours">—</p>
        </div>
        <div class="bg-gray-50 rounded-xl p-4 text-center">
          <p class="text-xs text-gray-500 mb-1">Total Minutes</p>
          <p class="text-lg font-bold tabular-nums text-gray-700" id="total-minutes">—</p>
        </div>
      </div>
    </section>

    <AdSlot slot="result" format="rectangle" />

    <section class="card mb-6">
      <h2 class="section-title"><span aria-hidden="true">✨</span> More Details</h2>
      <div class="space-y-3">
        <div class="flex justify-between py-2 border-b border-gray-100">
          <span class="text-gray-600">Born on</span>
          <span class="font-semibold text-gray-800" id="born-day">—</span>
        </div>
        <div class="flex justify-between py-2 border-b border-gray-100">
          <span class="text-gray-600">Next birthday</span>
          <span class="font-semibold text-gray-800" id="next-bday">—</span>
        </div>
        <div class="flex justify-between py-2">
          <span class="text-gray-600">Zodiac sign</span>
          <span class="font-semibold text-gray-800" id="zodiac">—</span>
        </div>
      </div>
    </section>

    <AdSlot slot="content" format="rectangle" />
  </div>

  <FAQ items={faqItems} title="Frequently Asked Questions" />

  <section class="card mt-6">
    <h2 class="section-title"><span aria-hidden="true">📚</span> Related guides</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
      {[
        { href: '/en/blog/how-to-calculate-exact-age', label: 'How to Calculate Exact Age', desc: 'See how years, months, and days are calculated from a date of birth.' },
        { href: '/en/blog/due-date-guide', label: 'How to Calculate Your Due Date', desc: 'Another practical date-based guide that uses exact calendar math.' },
      ].map((guide) => (
        <a href={guide.href} class="rounded-xl border border-gray-200 p-4 hover:border-primary-300 hover:bg-primary-50 transition-colors">
          <p class="font-semibold text-gray-800">{guide.label}</p>
          <p class="text-sm text-gray-500 mt-1">{guide.desc}</p>
        </a>
      ))}
    </div>
  </section>

  <RelatedCalculators current="age-calculator" />
</BaseLayout>

<script is:inline>
const DAYS = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
const MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];

function getZodiac(month, day) {
  if ((month === 3 && day >= 21) || (month === 4 && day <= 19)) return '♈ Aries';
  if ((month === 4 && day >= 20) || (month === 5 && day <= 20)) return '♉ Taurus';
  if ((month === 5 && day >= 21) || (month === 6 && day <= 20)) return '♊ Gemini';
  if ((month === 6 && day >= 21) || (month === 7 && day <= 22)) return '♋ Cancer';
  if ((month === 7 && day >= 23) || (month === 8 && day <= 22)) return '♌ Leo';
  if ((month === 8 && day >= 23) || (month === 9 && day <= 22)) return '♍ Virgo';
  if ((month === 9 && day >= 23) || (month === 10 && day <= 22)) return '♎ Libra';
  if ((month === 10 && day >= 23) || (month === 11 && day <= 21)) return '♏ Scorpio';
  if ((month === 11 && day >= 22) || (month === 12 && day <= 21)) return '♐ Sagittarius';
  if ((month === 12 && day >= 22) || (month === 1 && day <= 19)) return '♑ Capricorn';
  if ((month === 1 && day >= 20) || (month === 2 && day <= 18)) return '♒ Aquarius';
  return '♓ Pisces';
}

function calcAge() {
  const dobVal = document.getElementById('dob').value;
  const calcVal = document.getElementById('calc-date').value;
  if (!dobVal || !calcVal) { alert('Please enter a date of birth.'); return; }

  const dob = new Date(dobVal);
  const calc = new Date(calcVal);
  if (dob > calc) { alert('Date of birth must be before the calculation date.'); return; }

  let years = calc.getFullYear() - dob.getFullYear();
  let months = calc.getMonth() - dob.getMonth();
  let days = calc.getDate() - dob.getDate();

  if (days < 0) {
    months--;
    const prevMonth = new Date(calc.getFullYear(), calc.getMonth(), 0);
    days += prevMonth.getDate();
  }
  if (months < 0) { years--; months += 12; }

  const totalDays = Math.floor((calc - dob) / 86400000);
  const totalHours = totalDays * 24;
  const totalMinutes = totalHours * 60;

  document.getElementById('age-main').textContent = years + ' years, ' + months + ' months, ' + days + ' days';
  document.getElementById('age-sub').textContent = 'Exact age';
  document.getElementById('total-days').textContent = totalDays.toLocaleString('en-US');
  document.getElementById('total-hours').textContent = totalHours.toLocaleString('en-US');
  document.getElementById('total-minutes').textContent = totalMinutes.toLocaleString('en-US');

  document.getElementById('born-day').textContent = DAYS[dob.getDay()] + ', ' + MONTHS[dob.getMonth()] + ' ' + dob.getDate() + ', ' + dob.getFullYear();

  const thisYear = calc.getFullYear();
  let nextBday = new Date(thisYear, dob.getMonth(), dob.getDate());
  if (nextBday <= calc) nextBday = new Date(thisYear + 1, dob.getMonth(), dob.getDate());
  const daysUntil = Math.ceil((nextBday - calc) / 86400000);
  document.getElementById('next-bday').textContent = MONTHS[nextBday.getMonth()] + ' ' + nextBday.getDate() + ', ' + nextBday.getFullYear() + ' (in ' + daysUntil + ' days)';

  document.getElementById('zodiac').textContent = getZodiac(dob.getMonth() + 1, dob.getDate());

  const results = document.getElementById('age-results');
  results.classList.remove('hidden');
  results.scrollIntoView({ behavior: 'smooth', block: 'start' });
}

document.addEventListener('DOMContentLoaded', () => {
  document.getElementById('calc-age-btn').addEventListener('click', calcAge);
  document.getElementById('dob').addEventListener('keydown', e => { if (e.key === 'Enter') calcAge(); });
});
</script>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdSlot from '../../components/AdSlot.astro';
import { siteMeta } from '../../data/site-meta';

const title = 'Free Online Calculators — Finance, Health, Math & More';
const description = 'Free online calculators for mortgage, salary, BMI, compound interest, and more. Fast, accurate, and no signup required.';
const keywords = 'free online calculator, mortgage calculator, salary calculator, BMI calculator, compound interest calculator, percentage calculator';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'mycalcstool',
  url: 'https://mycalcstool.com/en/',
  description,
  inLanguage: 'en',
};

const categories = [
  {
    name: 'Finance',
    icon: '💰',
    calculators: [
      { icon: '🏠', title: 'Mortgage Calculator', desc: 'Estimate your monthly mortgage payment with taxes and insurance.', href: '/en/mortgage-calculator' },
      { icon: '💵', title: 'Salary Calculator', desc: 'Calculate your take-home pay after federal and state taxes.', href: '/en/salary-calculator' },
      { icon: '📈', title: 'Compound Interest Calculator', desc: 'See how your savings and investments grow over time.', href: '/en/compound-interest-calculator' },
    ],
  },
  {
    name: 'Health',
    icon: '❤️',
    calculators: [
      { icon: '⚖️', title: 'BMI Calculator', desc: 'Check your body mass index and healthy weight range.', href: '/en/bmi-calculator' },
      { icon: '🔥', title: 'TDEE / Calorie Calculator', desc: 'Find your total daily energy expenditure and calorie needs.', href: '/en/tdee-calculator' },
      { icon: '👶', title: 'Due Date Calculator', desc: 'Calculate your estimated pregnancy due date and milestones.', href: '/en/due-date-calculator' },
    ],
  },
  {
    name: 'Math & Utility',
    icon: '🧮',
    calculators: [
      { icon: '💯', title: 'Percentage Calculator', desc: 'Find percentages, percentage change, and percent of a number.', href: '/en/percentage-calculator' },
      { icon: '🎂', title: 'Age Calculator', desc: 'Calculate your exact age in years, months, days, and more.', href: '/en/age-calculator' },
      { icon: '🍽️', title: 'Tip Calculator', desc: 'Calculate gratuity and split the bill between multiple people.', href: '/en/tip-calculator' },
      { icon: '📐', title: 'Unit Converter', desc: 'Convert length, weight, temperature, volume, speed, and more.', href: '/en/unit-converter' },
    ],
  },
];

const financeCategory = categories.find((category) => category.name === 'Finance');
const supportingCategories = categories.filter((category) => category.name !== 'Finance');
---

<BaseLayout title={title} description={description} keywords={keywords} lang="en" jsonLd={jsonLd} hreflangKo="/">
  <div class="mb-8 text-center">
    <h1 class="text-3xl md:text-4xl font-bold text-gray-800 mb-3">Free Online Calculators</h1>
    <p class="text-gray-500 text-lg max-w-2xl mx-auto">Fast, accurate, and free. We prioritize finance calculators first, with health and utility tools as supporting calculators.</p>
  </div>

  <AdSlot slot="top" format="horizontal" />

  {financeCategory && (
    <section class="mb-10">
      <div class="flex items-center justify-between gap-3 mb-4 flex-wrap">
        <h2 class="text-xl font-bold text-gray-700 flex items-center gap-2">
          <span aria-hidden="true">{financeCategory.icon}</span> Featured Finance Calculators
        </h2>
        <a href="/en/methodology" class="text-sm font-semibold text-blue-600 hover:text-blue-700 transition-colors">Methodology →</a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
        {financeCategory.calculators.map(calc => (
          <a href={calc.href} class="card hover:shadow-md hover:border-primary-200 transition-all group flex flex-col gap-2 no-underline">
            <div class="text-3xl">{calc.icon}</div>
            <div class="font-semibold text-gray-800 group-hover:text-primary-600 transition-colors">{calc.title}</div>
            <div class="text-sm text-gray-500">{calc.desc}</div>
          </a>
        ))}
      </div>
    </section>
  )}

  <section class="mb-10">
    <h2 class="text-xl font-bold text-gray-700 mb-4 flex items-center gap-2">
      <span aria-hidden="true">🧰</span> Supporting Calculators
    </h2>
    <div class="space-y-8">
      {supportingCategories.map(cat => (
        <section>
          <h3 class="text-lg font-bold text-gray-700 mb-4 flex items-center gap-2">
            <span aria-hidden="true">{cat.icon}</span> {cat.name}
          </h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
            {cat.calculators.map(calc => (
              <a href={calc.href} class="card hover:shadow-md hover:border-primary-200 transition-all group flex flex-col gap-2 no-underline">
                <div class="text-3xl">{calc.icon}</div>
                <div class="font-semibold text-gray-800 group-hover:text-primary-600 transition-colors">{calc.title}</div>
                <div class="text-sm text-gray-500">{calc.desc}</div>
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>
  </section>

  <section class="card mt-4 bg-primary-50 border-primary-100">
    <h2 class="text-lg font-bold text-primary-800 mb-2">Why mycalcstool?</h2>
    <ul class="space-y-1 text-primary-700 text-sm list-disc list-inside">
      <li>100% free — no account, no fees</li>
      <li>All calculations happen in your browser — your data never leaves your device</li>
      <li>Updated for 2026 tax rates and rules</li>
      <li>Methodology and contact pages are published for correction requests</li>
      <li>Mobile-friendly and fast</li>
    </ul>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-gray-700 mb-4 flex items-center gap-2">
      <span aria-hidden="true">📝</span> Featured Finance Guides
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <a href="/en/blog/pmi-guide-how-private-mortgage-insurance-works" class="card hover:shadow-md hover:border-primary-200 transition-all group flex flex-col gap-2 no-underline">
        <div class="flex items-center gap-2 mb-1">
          <span class="text-xs font-semibold text-blue-600 bg-blue-50 px-2 py-0.5 rounded-full">Money & Finance</span>
          <span class="text-xs text-gray-400">8 min read</span>
        </div>
        <div class="font-semibold text-gray-800 group-hover:text-primary-600 transition-colors">PMI Guide: What Private Mortgage Insurance Costs and When It Ends</div>
        <div class="text-sm text-gray-500">Understand what PMI really adds to a mortgage payment and when borrowers can usually get rid of it.</div>
      </a>
      <a href="/en/blog/biweekly-vs-semi-monthly-pay-guide" class="card hover:shadow-md hover:border-primary-200 transition-all group flex flex-col gap-2 no-underline">
        <div class="flex items-center gap-2 mb-1">
          <span class="text-xs font-semibold text-blue-600 bg-blue-50 px-2 py-0.5 rounded-full">Money & Finance</span>
          <span class="text-xs text-gray-400">7 min read</span>
        </div>
        <div class="font-semibold text-gray-800 group-hover:text-primary-600 transition-colors">Biweekly vs Semi-Monthly Pay: Why Your Paycheck Amount Changes</div>
        <div class="text-sm text-gray-500">A practical guide to paycheck frequency, why the amount changes, and what that means for budgeting.</div>
      </a>
      <a href="/en/blog/simple-vs-compound-interest-guide" class="card hover:shadow-md hover:border-primary-200 transition-all group flex flex-col gap-2 no-underline">
        <div class="flex items-center gap-2 mb-1">
          <span class="text-xs font-semibold text-blue-600 bg-blue-50 px-2 py-0.5 rounded-full">Money & Finance</span>
          <span class="text-xs text-gray-400">7 min read</span>
        </div>
        <div class="font-semibold text-gray-800 group-hover:text-primary-600 transition-colors">Simple vs Compound Interest: Why Time Changes the Outcome</div>
        <div class="text-sm text-gray-500">See how compounding changes long-run results and why flat interest assumptions often understate growth.</div>
      </a>
    </div>
    <div class="mt-3 text-right">
      <a href="/en/blog/" class="text-sm font-semibold text-blue-600 hover:text-blue-700 transition-colors">View all articles →</a>
    </div>
  </section>

  <section class="card mt-10">
    <h2 class="text-lg font-bold text-gray-800 mb-3">Trust and contact</h2>
    <p class="text-sm text-gray-600 leading-relaxed">
      mycalcstool publishes methodology notes, policy pages, and a direct contact email for correction requests.
      Visit <a href="/en/about" class="font-semibold text-primary-600 hover:underline">About</a>,
      <a href="/en/methodology" class="font-semibold text-primary-600 hover:underline"> Methodology</a>, or
      <a href={`mailto:${siteMeta.contactEmail}`} class="font-semibold text-primary-600 hover:underline"> {siteMeta.contactEmail}</a>.
    </p>
  </section>
</BaseLayout>

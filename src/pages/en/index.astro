---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdSlot from '../../components/AdSlot.astro';
import { siteMeta } from '../../data/site-meta';

const title = 'Free Online Calculators — Finance, Health, Math & More';
const description = 'Free online calculators for mortgage, salary, BMI, compound interest, and more. Fast, accurate, and no signup required.';
const keywords = 'free online calculator, mortgage calculator, salary calculator, BMI calculator, compound interest calculator, percentage calculator';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'mycalcstool',
  url: 'https://mycalcstool.com/en/',
  description,
  inLanguage: 'en',
};

const popular = [
  {
    icon: '🏠',
    title: 'Mortgage Calculator',
    desc: 'Monthly payment, total interest, amortization schedule.',
    href: '/en/mortgage-calculator',
    badge: 'Most Popular',
  },
  {
    icon: '💵',
    title: 'Salary Calculator',
    desc: 'Take-home pay after federal and state taxes.',
    href: '/en/salary-calculator',
    badge: 'Finance',
  },
  {
    icon: '⚖️',
    title: 'BMI Calculator',
    desc: 'Body mass index and healthy weight range.',
    href: '/en/bmi-calculator',
    badge: 'Health',
  },
  {
    icon: '👶',
    title: 'Due Date Calculator',
    desc: 'Estimated pregnancy due date and week-by-week milestones.',
    href: '/en/due-date-calculator',
    badge: 'Health',
  },
];

const financeCalcs = [
  { icon: '🏠', title: 'Mortgage Calculator', desc: 'Monthly payment, interest, amortization.', href: '/en/mortgage-calculator' },
  { icon: '💵', title: 'Salary Calculator', desc: 'Take-home pay after federal and state taxes.', href: '/en/salary-calculator' },
  { icon: '📈', title: 'Compound Interest', desc: 'See how savings grow over time.', href: '/en/compound-interest-calculator' },
];

const healthCalcs = [
  { icon: '⚖️', title: 'BMI Calculator', desc: 'Body mass index and healthy weight range.', href: '/en/bmi-calculator' },
  { icon: '🔥', title: 'Calorie Calculator', desc: 'Daily calorie needs, BMR, TDEE, and macro targets.', href: '/en/calorie-calculator' },
  { icon: '🔥', title: 'TDEE Calculator', desc: 'Total daily energy expenditure and calorie needs.', href: '/en/tdee-calculator' },
  { icon: '👶', title: 'Due Date Calculator', desc: 'Pregnancy due date and milestones.', href: '/en/due-date-calculator' },
];

const utilityCalcs = [
  { icon: '💯', title: 'Percentage Calculator', desc: 'Percentages, change, and percent of a number.', href: '/en/percentage-calculator' },
  { icon: '🎂', title: 'Age Calculator', desc: 'Exact age in years, months, days, and more.', href: '/en/age-calculator' },
  { icon: '📅', title: 'Days Between Dates', desc: 'Count days, weeks, months until any event.', href: '/en/days-calculator' },
  { icon: '🍽️', title: 'Tip Calculator', desc: 'Gratuity and split the bill between people.', href: '/en/tip-calculator' },
  { icon: '📐', title: 'Unit Converter', desc: 'Length, weight, temperature, volume, speed.', href: '/en/unit-converter' },
];

const featuredPosts = [
  {
    href: '/en/blog/bmi-guide',
    title: 'What Is a Healthy BMI?',
    desc: 'What BMI means, how the categories work, and when body mass index needs extra context.',
    category: 'Health',
    readTime: '8 min',
  },
  {
    href: '/en/blog/how-many-calories-should-i-eat-per-day',
    title: 'How Many Calories Should I Eat Per Day?',
    desc: 'Use TDEE to estimate maintenance calories, fat-loss targets, and a realistic starting point.',
    category: 'Health',
    readTime: '8 min',
  },
  {
    href: '/en/blog/how-to-calculate-exact-age',
    title: 'How to Calculate Exact Age',
    desc: 'Learn how years, months, and days are calculated from a birth date without manual guesswork.',
    category: 'Math & Utility',
    readTime: '7 min',
  },
  {
    href: '/en/blog/due-date-guide',
    title: 'How to Calculate Your Due Date',
    desc: 'Naegele\'s Rule, ultrasound dating, IVF methods, and the 40-week timeline explained.',
    category: 'Health',
    readTime: '8 min',
  },
];
---

<BaseLayout title={title} description={description} keywords={keywords} lang="en" jsonLd={jsonLd} hreflangKo="/">

  <!-- Hero -->
  <div class="text-center mb-8">
    <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-2">Free Online Calculators</h1>
    <p class="text-gray-500 text-base max-w-xl mx-auto">No signup. No ads blocking your results. Just fast, accurate tools.</p>
  </div>

  <AdSlot slot="top" format="horizontal" />

  <!-- Most Popular -->
  <section class="mb-10">
    <h2 class="text-lg font-bold text-gray-700 mb-4">Most Popular Right Now</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {popular.map(calc => (
        <a href={calc.href} class="group bg-white rounded-2xl border border-gray-200 shadow-sm hover:shadow-md hover:border-blue-300 transition-all p-5 flex flex-col gap-3 no-underline">
          <div class="flex items-start justify-between gap-2">
            <div class="text-4xl leading-none">{calc.icon}</div>
            <span class="text-xs font-semibold text-blue-600 bg-blue-50 px-2 py-0.5 rounded-full shrink-0">{calc.badge}</span>
          </div>
          <div>
            <div class="font-bold text-gray-900 text-base group-hover:text-blue-600 transition-colors mb-1">{calc.title}</div>
            <div class="text-sm text-gray-500 leading-relaxed">{calc.desc}</div>
          </div>
          <div class="mt-auto pt-1">
            <span class="inline-flex items-center gap-1 text-sm font-semibold text-blue-600 group-hover:gap-2 transition-all">
              Use Calculator <span aria-hidden="true">→</span>
            </span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Finance Calculators -->
  <section class="mb-8">
    <div class="flex items-center justify-between gap-3 mb-4 flex-wrap">
      <h2 class="text-base font-bold text-gray-700 flex items-center gap-2">
        <span aria-hidden="true">💰</span> Finance Calculators
      </h2>
      <a href="/en/methodology" class="text-xs font-semibold text-blue-600 hover:text-blue-700 transition-colors">Methodology →</a>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
      {financeCalcs.map(calc => (
        <a href={calc.href} class="bg-white rounded-xl border border-gray-200 p-4 hover:shadow-md hover:border-blue-200 transition-all group flex flex-col gap-1 no-underline">
          <div class="text-2xl mb-1">{calc.icon}</div>
          <div class="font-semibold text-sm text-gray-800 group-hover:text-blue-600 transition-colors">{calc.title}</div>
          <div class="text-xs text-gray-500">{calc.desc}</div>
        </a>
      ))}
    </div>
  </section>

  <!-- Health Calculators -->
  <section class="mb-8">
    <h2 class="text-base font-bold text-gray-700 mb-4 flex items-center gap-2">
      <span aria-hidden="true">❤️</span> Health Calculators
    </h2>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
      {healthCalcs.map(calc => (
        <a href={calc.href} class="bg-white rounded-xl border border-gray-200 p-4 hover:shadow-md hover:border-blue-200 transition-all group flex flex-col gap-1 no-underline">
          <div class="text-2xl mb-1">{calc.icon}</div>
          <div class="font-semibold text-sm text-gray-800 group-hover:text-blue-600 transition-colors">{calc.title}</div>
          <div class="text-xs text-gray-500">{calc.desc}</div>
        </a>
      ))}
    </div>
  </section>

  <!-- Math & Utility Calculators -->
  <section class="mb-10">
    <h2 class="text-base font-bold text-gray-700 mb-4 flex items-center gap-2">
      <span aria-hidden="true">🧮</span> Math &amp; Utility
    </h2>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
      {utilityCalcs.map(calc => (
        <a href={calc.href} class="bg-white rounded-xl border border-gray-200 p-4 hover:shadow-md hover:border-blue-200 transition-all group flex flex-col gap-1 no-underline">
          <div class="text-2xl mb-1">{calc.icon}</div>
          <div class="font-semibold text-sm text-gray-800 group-hover:text-blue-600 transition-colors">{calc.title}</div>
          <div class="text-xs text-gray-500 hidden sm:block">{calc.desc}</div>
        </a>
      ))}
    </div>
  </section>

  <!-- Trust bar -->
  <section class="bg-gray-50 rounded-2xl border border-gray-100 px-6 py-4 mb-10">
    <div class="flex flex-wrap gap-x-6 gap-y-2 justify-center text-sm text-gray-600">
      <span class="flex items-center gap-1.5"><span class="text-green-500 font-bold">✓</span> 100% free, no account needed</span>
      <span class="flex items-center gap-1.5"><span class="text-green-500 font-bold">✓</span> Calculations run in your browser</span>
      <span class="flex items-center gap-1.5"><span class="text-green-500 font-bold">✓</span> Updated for 2026 tax rates</span>
      <span class="flex items-center gap-1.5"><span class="text-green-500 font-bold">✓</span> Mobile-friendly</span>
    </div>
  </section>

  <!-- Featured Blog Posts -->
  <section class="mb-10">
    <div class="flex items-center justify-between gap-3 mb-4 flex-wrap">
      <h2 class="text-base font-bold text-gray-700 flex items-center gap-2">
        <span aria-hidden="true">📝</span> Featured Guides
      </h2>
      <a href="/en/blog/" class="text-xs font-semibold text-blue-600 hover:text-blue-700 transition-colors">All articles →</a>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-4">
      {featuredPosts.map(post => (
        <a href={post.href} class="bg-white rounded-xl border border-gray-200 p-5 hover:shadow-md hover:border-blue-200 transition-all group flex flex-col gap-2 no-underline">
          <div class="flex items-center gap-2">
            <span class="text-xs font-semibold text-blue-600 bg-blue-50 px-2 py-0.5 rounded-full">{post.category}</span>
            <span class="text-xs text-gray-400">{post.readTime} read</span>
          </div>
          <div class="font-semibold text-sm text-gray-800 group-hover:text-blue-600 transition-colors leading-snug">{post.title}</div>
          <div class="text-xs text-gray-500 leading-relaxed">{post.desc}</div>
        </a>
      ))}
    </div>
  </section>

  <!-- Contact / Trust footer -->
  <section class="bg-white rounded-2xl border border-gray-100 shadow-sm px-6 py-4">
    <p class="text-sm text-gray-600 leading-relaxed text-center">
      Questions or corrections?
      <a href="/en/about" class="font-semibold text-blue-600 hover:underline mx-1">About</a>·
      <a href="/en/methodology" class="font-semibold text-blue-600 hover:underline mx-1">Methodology</a>·
      <a href={`mailto:${siteMeta.contactEmail}`} class="font-semibold text-blue-600 hover:underline mx-1">{siteMeta.contactEmail}</a>
    </p>
  </section>

</BaseLayout>

---
const targetPath = '/en/blog/how-to-calculate-exact-age/';
const canonicalUrl = 'https://mycalcstool.com/en/blog/how-to-calculate-exact-age/';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Redirecting to the age guide</title>
  <meta name="robots" content="noindex" />
  <link rel="canonical" href={canonicalUrl} />
  <meta http-equiv="refresh" content={`0;url=${targetPath}`} />
  <script is:inline>
    window.location.replace('/en/blog/how-to-calculate-exact-age/');
  </script>
</head>
<body>
  <p>Redirecting to <a href={targetPath}>the exact age guide</a>.</p>
</body>
</html>

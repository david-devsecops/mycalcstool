const title = '30-Year vs 15-Year Mortgage: Monthly Payment vs Total Interest';
const description = 'Compare 30-year and 15-year mortgages, including monthly payment, total interest, and long-term tradeoffs, before choosing a loan term.';
const keywords = '30 year vs 15 year mortgage, mortgage term comparison, total interest mortgage, mortgage payment guide';
const canonicalUrl = 'https://mycalcstool.com/en/blog/30-year-vs-15-year-mortgage-guide';
const publishDate = '2026-03-28';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  url: canonicalUrl,
  datePublished: publishDate,
  dateModified: publishDate,
  author: { '@type': 'Organization', name: 'mycalcstool', url: 'https://mycalcstool.com' },

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { siteMeta } from '../../data/site-meta';

const title = 'Contact';
const description = 'Contact mycalcstool for correction requests, policy questions, or partnership inquiries.';
---

<BaseLayout title={title} description={description} lang="en" hreflangKo="/contact">
  <div class="space-y-6">
    <section class="card">
      <h1 class="text-2xl font-bold text-gray-800 mb-4">Contact</h1>
      <p class="text-gray-600 leading-relaxed">
        For correction requests, policy questions, advertising issues, or partnerships, contact the site through the email below.
      </p>
      <a
        href={`mailto:${siteMeta.contactEmail}`}
        class="inline-flex mt-4 items-center gap-2 rounded-xl bg-primary-600 px-4 py-3 text-sm font-semibold text-white hover:bg-primary-700 transition-colors"
      >
        Email mycalcstool
        <span aria-hidden="true">→</span>
      </a>
      <p class="text-sm text-gray-500 mt-3">{siteMeta.contactEmail}</p>
    </section>

    <section class="card">
      <h2 class="text-xl font-bold text-gray-800 mb-4">Best way to report an issue</h2>
      <ul class="space-y-2 text-sm text-gray-600 list-disc pl-5">
        <li>Include the calculator name and page URL.</li>
        <li>Share the inputs you used and the result you expected.</li>
        <li>Link the official source or guidance if you are reporting a rate or rule change.</li>
      </ul>
    </section>

    <section class="card">
      <h2 class="text-xl font-bold text-gray-800 mb-4">Before you contact us</h2>
      <div class="space-y-3 text-sm text-gray-600">
        <p>Do not send sensitive personal data such as social security numbers, medical records, or bank account details.</p>
        <p>For financial, tax, legal, or medical decisions, verify important figures with an official source or licensed professional.</p>
        <p>Calculation assumptions are documented on the <a href="/en/methodology" class="text-primary-600 font-semibold hover:underline">Methodology</a> page.</p>
      </div>
    </section>
  </div>
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdSlot from '../../components/AdSlot.astro';
import FAQ from '../../components/FAQ.astro';
import RelatedCalculators from '../../components/RelatedCalculators.astro';

const title = 'Calorie Calculator 2026 — Daily Calorie Needs for Weight Loss, Maintenance & Gain';
const description = 'Calculate your daily calorie needs using the Mifflin-St Jeor formula. Get personalized BMR, TDEE, and target calories for weight loss, maintenance, or muscle gain.';
const keywords = 'calorie calculator, daily calorie needs, how many calories should I eat, BMR calculator, calorie deficit, weight loss calories, calorie intake calculator';

const faqItems = [
  {
    question: 'How many calories should I eat per day to lose weight?',
    answer: 'A daily deficit of 500 calories below your TDEE typically leads to about 1 lb (0.45 kg) of weight loss per week. This calculator shows you that exact target. Avoid dropping below 1,200 calories (women) or 1,500 calories (men) to prevent nutritional deficiencies.',
  },
  {
    question: 'What is the difference between BMR and TDEE?',
    answer: 'BMR (Basal Metabolic Rate) is the energy your body burns at complete rest — just to keep organs functioning. TDEE (Total Daily Energy Expenditure) multiplies your BMR by an activity factor to estimate actual daily calorie burn. TDEE is the number you should use for diet planning.',
  },
  {
    question: 'Which formula does this calculator use?',
    answer: 'This calculator uses the Mifflin-St Jeor equation, which is widely accepted as the most accurate for the general population. Men: BMR = (10 × weight in kg) + (6.25 × height in cm) − (5 × age) + 5. Women: BMR = (10 × weight in kg) + (6.25 × height in cm) − (5 × age) − 161.',
  },
  {
    question: 'How accurate are calorie calculators?',
    answer: 'Calorie calculators provide estimates with ±10–15% accuracy. Individual metabolism varies based on genetics, muscle mass, hormones, and gut health. Use the result as a starting point, then adjust by ±100–200 calories based on real-world results over 2–3 weeks.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Calorie Calculator',
  description,
  url: 'https://mycalcstool.com/en/calorie-calculator',
  applicationCategory: 'HealthApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  inLanguage: 'en',
};
---

<BaseLayout title={title} description={description} keywords={keywords} lang="en" jsonLd={jsonLd} hreflangKo="/calorie">
  <div class="mb-6">
    <nav class="text-sm text-gray-500 mb-2" aria-label="breadcrumb">
      <ol class="flex items-center gap-1 list-none p-0">
        <li><a href="/en/" class="hover:text-primary-600 transition-colors">Home</a></li>
        <li aria-hidden="true" class="text-gray-300">/</li>
        <li class="text-gray-700 font-medium" aria-current="page">Calorie Calculator</li>
      </ol>
    </nav>
    <h1 class="text-2xl md:text-3xl font-bold text-gray-800">🔥 Calorie Calculator</h1>
    <p class="text-gray-500 mt-2">Daily Calorie Needs · BMR · TDEE · Weight Loss & Gain Targets</p>
  </div>

  <AdSlot slot="top" format="horizontal" />

  <section class="card mb-6">
    <h2 class="section-title"><span aria-hidden="true">📝</span> Enter Your Details</h2>

    <!-- Unit toggle -->
    <div class="flex gap-3 mb-5">
      <button id="btn-imperial" class="flex-1 py-2 rounded-xl border-2 border-primary-500 bg-primary-50 text-primary-700 font-semibold text-sm transition-all" type="button" onclick="setUnit('imperial')">Imperial (lbs, ft/in)</button>
      <button id="btn-metric" class="flex-1 py-2 rounded-xl border-2 border-gray-200 text-gray-500 font-semibold text-sm transition-all" type="button" onclick="setUnit('metric')">Metric (kg, cm)</button>
    </div>

    <div class="space-y-4">
      <!-- Gender -->
      <div>
        <p class="block text-sm font-semibold text-gray-700 mb-2">Biological Sex</p>
        <div class="flex gap-3">
          <button id="btn-male" class="flex-1 py-2 rounded-xl border-2 border-primary-500 bg-primary-50 text-primary-700 font-semibold text-sm transition-all" type="button" onclick="setGender('male')">Male</button>
          <button id="btn-female" class="flex-1 py-2 rounded-xl border-2 border-gray-200 text-gray-500 font-semibold text-sm transition-all" type="button" onclick="setGender('female')">Female</button>
        </div>
      </div>

      <!-- Age -->
      <div>
        <label for="cal-age" class="block text-sm font-semibold text-gray-700 mb-1">Age</label>
        <div class="flex items-center gap-2">
          <input type="number" id="cal-age" class="input-field" value="30" min="15" max="100" step="1" inputmode="numeric" />
          <span class="text-gray-600 font-medium">years</span>
        </div>
      </div>

      <!-- Imperial height -->
      <div id="height-imperial">
        <label class="block text-sm font-semibold text-gray-700 mb-2">Height</label>
        <div class="flex gap-3">
          <div class="flex items-center gap-2 flex-1">
            <input type="number" id="height-ft" class="input-field" value="5" min="1" max="8" step="1" inputmode="numeric" />
            <span class="text-gray-600 font-medium whitespace-nowrap">ft</span>
          </div>
          <div class="flex items-center gap-2 flex-1">
            <input type="number" id="height-in" class="input-field" value="9" min="0" max="11" step="1" inputmode="numeric" />
            <span class="text-gray-600 font-medium whitespace-nowrap">in</span>
          </div>
        </div>
      </div>

      <!-- Metric height -->
      <div id="height-metric" class="hidden">
        <label for="height-cm" class="block text-sm font-semibold text-gray-700 mb-1">Height</label>
        <div class="flex items-center gap-2">
          <input type="number" id="height-cm" class="input-field" value="175" min="50" max="300" step="1" inputmode="numeric" />
          <span class="text-gray-600 font-medium">cm</span>
        </div>
        <input type="range" id="height-cm-slider" class="range-slider mt-2" min="100" max="250" step="1" value="175" />
      </div>

      <!-- Imperial weight -->
      <div id="weight-imperial">
        <label for="weight-lbs" class="block text-sm font-semibold text-gray-700 mb-1">Weight</label>
        <div class="flex items-center gap-2">
          <input type="number" id="weight-lbs" class="input-field" value="160" min="50" max="700" step="0.5" inputmode="decimal" />
          <span class="text-gray-600 font-medium">lbs</span>
        </div>
        <input type="range" id="weight-lbs-slider" class="range-slider mt-2" min="80" max="400" step="1" value="160" />
      </div>

      <!-- Metric weight -->
      <div id="weight-metric" class="hidden">
        <label for="weight-kg" class="block text-sm font-semibold text-gray-700 mb-1">Weight</label>
        <div class="flex items-center gap-2">
          <input type="number" id="weight-kg" class="input-field" value="70" min="20" max="300" step="0.5" inputmode="decimal" />
          <span class="text-gray-600 font-medium">kg</span>
        </div>
        <input type="range" id="weight-kg-slider" class="range-slider mt-2" min="30" max="200" step="0.5" value="70" />
      </div>

      <!-- Activity level -->
      <div>
        <label for="activity" class="block text-sm font-semibold text-gray-700 mb-1">Activity Level</label>
        <select id="activity" class="input-field">
          <option value="1.2">Sedentary — desk job, little to no exercise</option>
          <option value="1.375" selected>Lightly active — light exercise 1–3 days/week</option>
          <option value="1.55">Moderately active — moderate exercise 3–5 days/week</option>
          <option value="1.725">Very active — hard exercise 6–7 days/week</option>
          <option value="1.9">Extra active — physical job or twice-daily training</option>
        </select>
      </div>

      <button id="calc-cal-btn" class="btn-primary" type="button">Calculate My Calories</button>
    </div>
  </section>

  <!-- Results -->
  <div id="cal-results" class="hidden" aria-live="polite">
    <section class="card mb-6">
      <h2 class="section-title"><span aria-hidden="true">📊</span> Your Calorie Needs</h2>

      <!-- BMR + TDEE highlight -->
      <div class="grid grid-cols-2 gap-4 mb-6">
        <div class="bg-gray-50 rounded-xl p-4 text-center">
          <p class="text-xs text-gray-500 mb-1">BMR (at rest)</p>
          <p class="text-3xl font-bold text-gray-700 tabular-nums" id="bmr-val">—</p>
          <p class="text-xs text-gray-400 mt-1">kcal / day</p>
        </div>
        <div class="bg-primary-50 rounded-xl p-4 text-center border border-primary-200">
          <p class="text-xs text-primary-600 mb-1 font-semibold">TDEE (maintenance)</p>
          <p class="text-3xl font-bold text-primary-700 tabular-nums" id="tdee-val">—</p>
          <p class="text-xs text-primary-400 mt-1">kcal / day</p>
        </div>
      </div>

      <!-- Goal calories -->
      <h3 class="text-sm font-semibold text-gray-600 mb-3">Recommended Daily Calories by Goal</h3>
      <div class="space-y-3">
        <div class="flex items-center justify-between bg-blue-50 rounded-xl px-4 py-3">
          <div>
            <p class="font-semibold text-blue-700 text-sm">🏃 Weight Loss</p>
            <p class="text-xs text-blue-500">−500 kcal/day → ~1 lb/week loss</p>
          </div>
          <p class="text-xl font-bold text-blue-700 tabular-nums" id="loss-val">—</p>
        </div>
        <div class="flex items-center justify-between bg-green-50 rounded-xl px-4 py-3">
          <div>
            <p class="font-semibold text-green-700 text-sm">⚖️ Maintenance</p>
            <p class="text-xs text-green-500">Keep current weight</p>
          </div>
          <p class="text-xl font-bold text-green-700 tabular-nums" id="maintain-val">—</p>
        </div>
        <div class="flex items-center justify-between bg-orange-50 rounded-xl px-4 py-3">
          <div>
            <p class="font-semibold text-orange-700 text-sm">💪 Muscle Gain</p>
            <p class="text-xs text-orange-500">+300 kcal/day lean bulk</p>
          </div>
          <p class="text-xl font-bold text-orange-700 tabular-nums" id="gain-val">—</p>
        </div>
      </div>
    </section>

    <AdSlot slot="result" format="rectangle" />

    <!-- Macros -->
    <section class="card mb-6">
      <h2 class="section-title"><span aria-hidden="true">🥗</span> Macronutrient Breakdown <span class="text-sm font-normal text-gray-400">(maintenance)</span></h2>
      <div class="grid grid-cols-3 gap-3">
        <div class="bg-yellow-50 rounded-xl p-4 text-center">
          <p class="text-xs text-yellow-600 mb-1 font-semibold">Carbs (50%)</p>
          <p class="text-2xl font-bold text-yellow-700 tabular-nums" id="carb-val">—</p>
          <p class="text-xs text-yellow-500 mt-1">grams</p>
        </div>
        <div class="bg-red-50 rounded-xl p-4 text-center">
          <p class="text-xs text-red-600 mb-1 font-semibold">Protein (30%)</p>
          <p class="text-2xl font-bold text-red-700 tabular-nums" id="protein-val">—</p>
          <p class="text-xs text-red-500 mt-1">grams</p>
        </div>
        <div class="bg-purple-50 rounded-xl p-4 text-center">
          <p class="text-xs text-purple-600 mb-1 font-semibold">Fat (20%)</p>
          <p class="text-2xl font-bold text-purple-700 tabular-nums" id="fat-val">—</p>
          <p class="text-xs text-purple-500 mt-1">grams</p>
        </div>
      </div>
      <p class="text-xs text-gray-400 mt-3 text-center">Based on a 50/30/20 carb/protein/fat split. Adjust to your needs.</p>
    </section>

    <AdSlot slot="content" format="rectangle" />
  </div>

  <FAQ items={faqItems} title="Frequently Asked Questions" />

  <section class="card mt-6">
    <h2 class="section-title"><span aria-hidden="true">📚</span> Related guides</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
      {[
        { href: '/en/blog/how-many-calories-should-i-eat-per-day', label: 'How Many Calories Should I Eat Per Day?', desc: 'A deep dive into calorie targets, activity multipliers, and why estimates vary.' },
        { href: '/en/blog/calorie-deficit-guide-using-tdee', label: 'How to Use TDEE to Create a Calorie Deficit', desc: 'Use your TDEE to set an evidence-based calorie deficit for sustainable weight loss.' },
        { href: '/en/blog/calorie-calculator-guide', label: 'Calorie Calculator Guide: How to Use It Right', desc: 'Step-by-step guide to using calorie calculators effectively for your goals.' },
      ].map((guide) => (
        <a href={guide.href} class="rounded-xl border border-gray-200 p-4 hover:border-primary-300 hover:bg-primary-50 transition-colors">
          <p class="font-semibold text-gray-800">{guide.label}</p>
          <p class="text-sm text-gray-500 mt-1">{guide.desc}</p>
        </a>
      ))}
    </div>
  </section>

  <RelatedCalculators current="calorie-calculator" />
</BaseLayout>

<script is:inline>
let currentUnit = 'imperial';
let currentGender = 'male';

function setUnit(unit) {
  currentUnit = unit;
  ['imperial','metric'].forEach(u => {
    const active = u === unit;
    const btn = document.getElementById('btn-' + u);
    btn.classList.toggle('border-primary-500', active);
    btn.classList.toggle('bg-primary-50', active);
    btn.classList.toggle('text-primary-700', active);
    btn.classList.toggle('border-gray-200', !active);
    btn.classList.toggle('text-gray-500', !active);
    document.getElementById('height-' + u).classList.toggle('hidden', !active);
    document.getElementById('weight-' + u).classList.toggle('hidden', !active);
  });
}

function setGender(g) {
  currentGender = g;
  ['male','female'].forEach(x => {
    const active = x === g;
    const btn = document.getElementById('btn-' + x);
    btn.classList.toggle('border-primary-500', active);
    btn.classList.toggle('bg-primary-50', active);
    btn.classList.toggle('text-primary-700', active);
    btn.classList.toggle('border-gray-200', !active);
    btn.classList.toggle('text-gray-500', !active);
  });
}

function fmt(n) {
  return Math.round(n).toLocaleString('en-US');
}

function calcCalories() {
  let weightKg, heightCm;
  const age = parseInt(document.getElementById('cal-age').value);
  if (!age || age < 15 || age > 100) { alert('Please enter a valid age (15–100).'); return; }

  if (currentUnit === 'imperial') {
    const ft = parseFloat(document.getElementById('height-ft').value) || 0;
    const inch = parseFloat(document.getElementById('height-in').value) || 0;
    const lbs = parseFloat(document.getElementById('weight-lbs').value);
    if (isNaN(lbs) || lbs <= 0 || (ft === 0 && inch === 0)) { alert('Please enter valid height and weight.'); return; }
    heightCm = (ft * 12 + inch) * 2.54;
    weightKg = lbs * 0.453592;
  } else {
    heightCm = parseFloat(document.getElementById('height-cm').value);
    weightKg = parseFloat(document.getElementById('weight-kg').value);
    if (isNaN(heightCm) || isNaN(weightKg) || heightCm <= 0 || weightKg <= 0) { alert('Please enter valid height and weight.'); return; }
  }

  // Mifflin-St Jeor
  const bmr = currentGender === 'male'
    ? (10 * weightKg) + (6.25 * heightCm) - (5 * age) + 5
    : (10 * weightKg) + (6.25 * heightCm) - (5 * age) - 161;

  const activity = parseFloat(document.getElementById('activity').value);
  const tdee = bmr * activity;

  document.getElementById('bmr-val').textContent = fmt(bmr);
  document.getElementById('tdee-val').textContent = fmt(tdee);
  document.getElementById('loss-val').textContent = fmt(tdee - 500) + ' kcal';
  document.getElementById('maintain-val').textContent = fmt(tdee) + ' kcal';
  document.getElementById('gain-val').textContent = fmt(tdee + 300) + ' kcal';

  // Macros for maintenance (50/30/20)
  document.getElementById('carb-val').textContent = fmt(tdee * 0.50 / 4);
  document.getElementById('protein-val').textContent = fmt(tdee * 0.30 / 4);
  document.getElementById('fat-val').textContent = fmt(tdee * 0.20 / 9);

  const results = document.getElementById('cal-results');
  results.classList.remove('hidden');
  results.scrollIntoView({ behavior: 'smooth', block: 'start' });
}

document.addEventListener('DOMContentLoaded', () => {
  document.getElementById('calc-cal-btn').addEventListener('click', calcCalories);

  // Slider sync
  const pairs = [
    ['height-cm-slider', 'height-cm'],
    ['weight-lbs-slider', 'weight-lbs'],
    ['weight-kg-slider', 'weight-kg'],
  ];
  pairs.forEach(([sliderId, inputId]) => {
    const slider = document.getElementById(sliderId);
    const input = document.getElementById(inputId);
    if (slider && input) {
      slider.addEventListener('input', () => { input.value = slider.value; });
      input.addEventListener('input', () => { slider.value = input.value; });
    }
  });
});
</script>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { koFinanceGuides } from '../../data/ko-finance-guides';

const title = '금융 계산기 가이드 - 대출, 연봉, 연말정산, 복리';
const description = '대출 상환 방식, 연봉 실수령액, 연말정산, 퇴직금, 복리 계산기를 이해하기 위한 한국어 금융 가이드 모음입니다.';
const keywords = '대출 가이드, 연봉 실수령액, 연말정산 가이드, 퇴직금 계산, 복리 가이드';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'mycalcstool 금융 가이드',
  description,
  url: 'https://mycalcstool.com/blog/',
  inLanguage: 'ko',
};
---

<BaseLayout title={title} description={description} keywords={keywords} jsonLd={jsonLd} hreflangEn="/en/blog/">
  <div class="mb-6">
    <nav class="text-sm text-gray-500 mb-2" aria-label="breadcrumb">
      <ol class="flex items-center gap-1 list-none p-0">
        <li><a href="/" class="hover:text-primary-600 transition-colors">홈</a></li>
        <li aria-hidden="true" class="text-gray-300">/</li>
        <li class="text-gray-700 font-medium" aria-current="page">금융 가이드</li>
      </ol>
    </nav>
    <h1 class="text-2xl md:text-3xl font-bold text-gray-800">금융 계산기 가이드</h1>
    <p class="text-gray-500 mt-2">대출, 연봉, 연말정산, 퇴직금, 복리 계산기를 더 정확히 해석하기 위한 설명형 문서입니다.</p>
  </div>

  <section class="card mb-8 bg-primary-50 border-primary-100">
    <h2 class="text-lg font-bold text-primary-800 mb-3">읽는 순서</h2>
    <ul class="text-sm text-primary-700 list-disc pl-5 space-y-1">
      <li>대출을 계산한다면 상환 방식과 금리 구조 글부터 보세요.</li>
      <li>실수령액과 연말정산은 함께 봐야 월급과 환급의 연결이 보입니다.</li>
      <li>퇴직금과 복리는 장기 계획 영역이라 계산식보다 가정값 이해가 중요합니다.</li>
    </ul>
  </section>

  <section>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {koFinanceGuides.map((post) => (
        <article class="card hover:shadow-md hover:border-primary-200 transition-all">
          <div class="flex items-center gap-2 mb-2">
            <span class="text-xs font-semibold text-primary-600 bg-primary-50 px-2 py-0.5 rounded-full">{post.category}</span>
            <span class="text-xs text-gray-400">{post.readTime}</span>
          </div>
          <a href={post.href} class="block group">
            <h2 class="text-lg font-bold text-gray-900 group-hover:text-primary-600 transition-colors">{post.title}</h2>
            <p class="text-sm text-gray-500 mt-2 leading-relaxed">{post.description}</p>
          </a>
          <div class="mt-3 flex items-center justify-between">
            <time class="text-xs text-gray-400" datetime={post.date}>
              {new Date(post.date).toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
            <a href={post.href} class="text-sm font-semibold text-primary-600 hover:text-primary-700 transition-colors">읽기 →</a>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>

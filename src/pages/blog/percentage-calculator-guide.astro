const description = '퍼센트 계산 공식, 할인 후 가격 계산, 연봉 인상률·이자율 계산에 바로 쓰는 퍼센트 활용법을 정리합니다.';
const keywords = '퍼센트 계산, 비율 계산, 할인율 계산, 증가율 계산, % 계산 방법, 퍼센트 공식';

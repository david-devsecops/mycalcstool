---
import BaseLayout from '../layouts/BaseLayout.astro';
import AdSlot from '../components/AdSlot.astro';
import FAQ from '../components/FAQ.astro';

const title = '나이 계산기 - 만 나이·한국식 나이·연 나이 한번에 계산';
const description = '생년월일을 입력하면 만 나이(공식), 한국식 나이, 연 나이를 즉시 계산합니다. 태어난 요일, 다음 생일까지 남은 날, 총 살아온 일수도 확인하세요.';
const keywords = '나이 계산기, 만 나이 계산기, 한국식 나이 계산, 내 나이 계산, 생년월일 나이 계산, 만 나이 계산법';

const faqItems = [
  {
    question: '만 나이와 한국식 나이의 차이는 무엇인가요?',
    answer: '만 나이는 생일이 지난 경우 현재 연도에서 출생 연도를 뺀 값, 생일이 지나지 않았으면 1을 추가로 뺀 값입니다. 2023년 6월부터 한국도 공식적으로 만 나이를 사용합니다. 한국식 나이(세는 나이)는 태어난 해를 1살로 보고 새해 1월 1일마다 1살씩 늘어납니다.',
  },
  {
    question: '연 나이는 무엇인가요?',
    answer: '연 나이는 현재 연도에서 출생 연도를 뺀 값입니다. 생일과 무관하게 계산되며, 병역법·청소년보호법 등 일부 법령에서 사용하는 나이 기준입니다.',
  },
  {
    question: '생일이 지났는지 여부가 만 나이에 영향을 주나요?',
    answer: '네. 올해 생일이 지났으면 현재 연도 − 출생 연도, 아직 지나지 않았으면 현재 연도 − 출생 연도 − 1이 됩니다. 예를 들어 1990년 12월생은 2025년 1월 기준 만 34세, 2025년 12월 생일 이후로는 만 35세가 됩니다.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: '나이 계산기',
  description,
  url: 'https://mycalcstool.com/age-calculator',
  applicationCategory: 'UtilitiesApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'KRW' },
  inLanguage: 'ko',
};
---

<BaseLayout title={title} description={description} keywords={keywords} jsonLd={jsonLd} hreflangEn="/en/age-calculator">
  <div class="mb-6">
    <nav class="text-sm text-gray-500 mb-2" aria-label="breadcrumb">
      <ol class="flex items-center gap-1 list-none p-0">
        <li><a href="/" class="hover:text-primary-600 transition-colors">홈</a></li>
        <li aria-hidden="true" class="text-gray-300">/</li>
        <li class="text-gray-700 font-medium" aria-current="page">나이 계산기</li>
      </ol>
    </nav>
    <h1 class="text-2xl md:text-3xl font-bold text-gray-800">🎂 나이 계산기</h1>
    <p class="text-gray-500 mt-2">만 나이 · 한국식 나이 · 연 나이를 한번에 확인하세요</p>
  </div>

  <AdSlot slot="top" format="horizontal" />

  <section class="card mb-6">
    <h2 class="section-title"><span aria-hidden="true">📅</span> 생년월일 입력</h2>
    <div class="space-y-4">
      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-1">생년월일</label>
        <div class="grid grid-cols-3 gap-3">
          <select id="dob-year" class="input-field" aria-label="출생 연도"></select>
          <select id="dob-month" class="input-field" aria-label="출생 월"></select>
          <select id="dob-day" class="input-field" aria-label="출생 일"></select>
        </div>
      </div>
      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-1">기준일 <span class="text-gray-400 font-normal">(오늘)</span></label>
        <div class="grid grid-cols-3 gap-3">
          <select id="calc-year" class="input-field" aria-label="기준 연도"></select>
          <select id="calc-month" class="input-field" aria-label="기준 월"></select>
          <select id="calc-day" class="input-field" aria-label="기준 일"></select>
        </div>
      </div>
      <button id="calc-age-btn" class="btn-primary" type="button">🔍 나이 계산하기</button>
    </div>
  </section>

  <div id="age-results" class="hidden" aria-live="polite">
    <section class="card mb-6">
      <h2 class="section-title"><span aria-hidden="true">🎉</span> 나이 결과</h2>

      <!-- 3가지 나이 -->
      <div class="grid grid-cols-3 gap-3 mb-6">
        <div class="bg-primary-50 rounded-xl p-4 text-center border border-primary-100">
          <p class="text-xs text-primary-600 font-semibold mb-1">만 나이 <span class="text-[10px] text-primary-400">(공식)</span></p>
          <p class="text-3xl font-bold tabular-nums text-primary-700" id="age-man">—</p>
          <p class="text-xs text-gray-400 mt-1">세</p>
        </div>
        <div class="bg-gray-50 rounded-xl p-4 text-center">
          <p class="text-xs text-gray-500 font-semibold mb-1">한국식 나이</p>
          <p class="text-3xl font-bold tabular-nums text-gray-700" id="age-korean">—</p>
          <p class="text-xs text-gray-400 mt-1">세</p>
        </div>
        <div class="bg-gray-50 rounded-xl p-4 text-center">
          <p class="text-xs text-gray-500 font-semibold mb-1">연 나이</p>
          <p class="text-3xl font-bold tabular-nums text-gray-700" id="age-year">—</p>
          <p class="text-xs text-gray-400 mt-1">세</p>
        </div>
      </div>

      <!-- 상세 정보 -->
      <div class="grid grid-cols-3 gap-3 mb-4">
        <div class="bg-gray-50 rounded-xl p-4 text-center">
          <p class="text-xs text-gray-500 mb-1">총 일수</p>
          <p class="text-lg font-bold tabular-nums text-gray-700" id="total-days">—</p>
        </div>
        <div class="bg-gray-50 rounded-xl p-4 text-center">
          <p class="text-xs text-gray-500 mb-1">총 시간</p>
          <p class="text-lg font-bold tabular-nums text-gray-700" id="total-hours">—</p>
        </div>
        <div class="bg-gray-50 rounded-xl p-4 text-center">
          <p class="text-xs text-gray-500 mb-1">총 분</p>
          <p class="text-lg font-bold tabular-nums text-gray-700" id="total-minutes">—</p>
        </div>
      </div>
      <div class="space-y-3">
        <div class="flex justify-between py-2 border-b border-gray-100">
          <span class="text-gray-600 text-sm">태어난 요일</span>
          <span class="font-semibold text-gray-800 text-sm" id="born-day">—</span>
        </div>
        <div class="flex justify-between py-2 border-b border-gray-100">
          <span class="text-gray-600 text-sm">다음 생일</span>
          <span class="font-semibold text-gray-800 text-sm" id="next-bday">—</span>
        </div>
        <div class="flex justify-between py-2">
          <span class="text-gray-600 text-sm">띠</span>
          <span class="font-semibold text-gray-800 text-sm" id="zodiac-ko">—</span>
        </div>
      </div>
    </section>

    <AdSlot slot="result" format="rectangle" />
    <AdSlot slot="content" format="rectangle" />
  </div>

  <!-- SEO 콘텐츠 -->
  <section class="card mb-6">
    <h2 class="section-title"><span aria-hidden="true">📖</span> 만 나이 계산법 가이드</h2>
    <div class="text-gray-700 space-y-4 leading-relaxed text-sm">
      <p>2023년 6월 28일부터 한국의 공식 나이는 <strong>만 나이</strong>로 통일되었습니다. 행정·법률·의료 등 공공 영역에서는 만 나이를 기준으로 합니다.</p>
      <h3 class="text-base font-bold text-gray-800">세 가지 나이 계산 방식 비교</h3>
      <div class="overflow-x-auto">
        <table class="w-full text-sm border border-gray-200 rounded-lg">
          <thead>
            <tr class="bg-gray-50">
              <th class="px-3 py-2 text-left font-semibold text-gray-700">구분</th>
              <th class="px-3 py-2 text-left font-semibold text-gray-700">계산 방법</th>
              <th class="px-3 py-2 text-left font-semibold text-gray-700">사용 분야</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <tr><td class="px-3 py-2 font-medium">만 나이</td><td class="px-3 py-2 text-gray-600">생일 기준 정확 계산</td><td class="px-3 py-2 text-gray-600">공식, 법령, 의료</td></tr>
            <tr><td class="px-3 py-2 font-medium">한국식 나이</td><td class="px-3 py-2 text-gray-600">태어난 해 = 1살, 매년 1월 1일 +1</td><td class="px-3 py-2 text-gray-600">일상 대화</td></tr>
            <tr><td class="px-3 py-2 font-medium">연 나이</td><td class="px-3 py-2 text-gray-600">현재 연도 − 출생 연도</td><td class="px-3 py-2 text-gray-600">병역법, 청소년법</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <FAQ items={faqItems} />

  <section class="card mt-6">
    <h2 class="section-title"><span aria-hidden="true">🔗</span> 관련 계산기</h2>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
      {[
        { href: '/due-date', label: '👶 출산 예정일', desc: '출산 날짜 계산' },
        { href: '/dday', label: '📅 D-day 계산기', desc: '날짜 간격 계산' },
        { href: '/bmi', label: '⚖️ BMI 계산기', desc: '건강 체중 확인' },
      ].map(l => (
        <a href={l.href} class="p-3 border border-gray-200 rounded-lg hover:border-primary-300 hover:bg-primary-50 transition-colors group">
          <div class="font-medium text-sm text-gray-700 group-hover:text-primary-600">{l.label}</div>
          <div class="text-xs text-gray-400 mt-0.5">{l.desc}</div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<script is:inline>
const DAYS_KO = ['일','월','화','수','목','금','토'];
const MONTHS_KO = ['1월','2월','3월','4월','5월','6월','7월','8월','9월','10월','11월','12월'];
const ZODIACS_KO = ['원숭이','닭','개','돼지','쥐','소','호랑이','토끼','용','뱀','말','양'];
const TODAY = new Date();

function pad2(v) { return String(v).padStart(2, '0'); }

function populateYears(id, start, end) {
  const sel = document.getElementById(id);
  let html = '<option value="">연도</option>';
  for (let y = end; y >= start; y--) html += `<option value="${y}">${y}년</option>`;
  sel.innerHTML = html;
}

function populateMonths(id) {
  const sel = document.getElementById(id);
  sel.innerHTML = '<option value="">월</option>' + MONTHS_KO.map((m,i) => `<option value="${i+1}">${m}</option>`).join('');
}

function syncDays(prefix) {
  const y = parseInt(document.getElementById(prefix + '-year').value);
  const m = parseInt(document.getElementById(prefix + '-month').value);
  const sel = document.getElementById(prefix + '-day');
  const cur = sel.value;
  const max = (y && m) ? new Date(y, m, 0).getDate() : 31;
  let html = '<option value="">일</option>';
  for (let d = 1; d <= max; d++) html += `<option value="${d}">${d}일</option>`;
  sel.innerHTML = html;
  if (cur && parseInt(cur) <= max) sel.value = cur;
}

function setDate(prefix, y, m, d) {
  document.getElementById(prefix + '-year').value = String(y);
  document.getElementById(prefix + '-month').value = String(m);
  syncDays(prefix);
  document.getElementById(prefix + '-day').value = String(d);
}

function getDate(prefix) {
  const y = document.getElementById(prefix + '-year').value;
  const m = document.getElementById(prefix + '-month').value;
  const d = document.getElementById(prefix + '-day').value;
  if (!y || !m || !d) return null;
  return new Date(parseInt(y), parseInt(m) - 1, parseInt(d));
}

function getZodiacKo(year) {
  return ZODIACS_KO[(year - 2016 % 12 + 1200) % 12] + '띠';
}

function calcAge() {
  const dob = getDate('dob');
  const calc = getDate('calc');
  if (!dob) { alert('생년월일을 입력해주세요.'); return; }
  if (!calc) { alert('기준일을 입력해주세요.'); return; }
  if (dob > calc) { alert('생년월일이 기준일보다 이후입니다.'); return; }

  // 만 나이
  let manAge = calc.getFullYear() - dob.getFullYear();
  const hadBirthday = (calc.getMonth() > dob.getMonth()) ||
    (calc.getMonth() === dob.getMonth() && calc.getDate() >= dob.getDate());
  if (!hadBirthday) manAge--;

  // 한국식 나이: 태어난 해 = 1살, 새해 +1
  const koreanAge = calc.getFullYear() - dob.getFullYear() + 1;

  // 연 나이
  const yearAge = calc.getFullYear() - dob.getFullYear();

  const totalDays = Math.floor((calc - dob) / 86400000);
  const totalHours = totalDays * 24;
  const totalMinutes = totalHours * 60;

  function set(id, val) { const e = document.getElementById(id); if (e) e.textContent = val; }

  set('age-man', manAge.toLocaleString('ko-KR'));
  set('age-korean', koreanAge.toLocaleString('ko-KR'));
  set('age-year', yearAge.toLocaleString('ko-KR'));
  set('total-days', totalDays.toLocaleString('ko-KR') + '일');
  set('total-hours', totalHours.toLocaleString('ko-KR') + '시간');
  set('total-minutes', totalMinutes.toLocaleString('ko-KR') + '분');
  set('born-day', `${dob.getFullYear()}년 ${dob.getMonth()+1}월 ${dob.getDate()}일 (${DAYS_KO[dob.getDay()]}요일)`);

  const cy = calc.getFullYear();
  let nextBday = new Date(cy, dob.getMonth(), dob.getDate());
  if (nextBday <= calc) nextBday = new Date(cy + 1, dob.getMonth(), dob.getDate());
  const daysUntil = Math.ceil((nextBday - calc) / 86400000);
  set('next-bday', `${nextBday.getFullYear()}년 ${nextBday.getMonth()+1}월 ${nextBday.getDate()}일 (${daysUntil}일 후)`);

  set('zodiac-ko', getZodiacKo(dob.getFullYear()));

  const results = document.getElementById('age-results');
  results.classList.remove('hidden');
  results.scrollIntoView({ behavior: 'smooth', block: 'start' });
}

document.addEventListener('DOMContentLoaded', () => {
  const cy = TODAY.getFullYear();
  populateYears('dob-year', cy - 120, cy);
  populateMonths('dob-month');
  syncDays('dob');
  populateYears('calc-year', cy - 120, cy + 10);
  populateMonths('calc-month');
  syncDays('calc');

  ['dob','calc'].forEach(prefix => {
    document.getElementById(prefix + '-month').addEventListener('change', () => syncDays(prefix));
    document.getElementById(prefix + '-year').addEventListener('change', () => syncDays(prefix));
  });

  setDate('calc', cy, TODAY.getMonth() + 1, TODAY.getDate());
  document.getElementById('calc-age-btn').addEventListener('click', calcAge);
});
</script>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import AdSlot from '../components/AdSlot.astro';
import FAQ from '../components/FAQ.astro';

const title = '일일 칼로리 계산기 2026 - 기초대사량·TDEE·목표 칼로리 계산';
const description = '성별, 나이, 키, 몸무게, 활동량을 입력하면 Mifflin-St Jeor 공식으로 기초대사량(BMR)과 일일 소비 칼로리(TDEE)를 계산합니다. 체중 감량·유지·증량별 권장 칼로리와 탄수화물·단백질·지방 섭취량도 확인하세요.';
const keywords = '일일 칼로리 계산기, 기초대사량 계산기, TDEE 계산기, 하루 칼로리 필요량, BMR 계산, 칼로리 계산, 체중 감량 칼로리, 다이어트 칼로리, Mifflin-St Jeor';

const faqItems = [
  {
    question: '기초대사량(BMR)과 TDEE의 차이는 무엇인가요?',
    answer: '기초대사량(BMR, Basal Metabolic Rate)은 아무것도 하지 않고 누워만 있어도 생명 유지에 필요한 최소 칼로리입니다. TDEE(Total Daily Energy Expenditure)는 BMR에 일상 활동량을 곱한 값으로, 실제 하루에 소비하는 총 칼로리를 의미합니다. 체중 관리의 기준이 되는 수치는 TDEE입니다.',
  },
  {
    question: '다이어트 시 칼로리를 얼마나 줄여야 하나요?',
    answer: '하루 500kcal 결핍을 만들면 1주에 약 0.5kg 감량이 가능합니다. 이 계산기에서는 TDEE에서 500kcal를 뺀 값을 감량 목표로 제시합니다. 단, 여성은 1,200kcal, 남성은 1,500kcal 미만으로 섭취하면 영양 부족이 생길 수 있으니 주의하세요. 급격한 칼로리 제한보다 운동 병행을 권장합니다.',
  },
  {
    question: '활동량 단계는 어떻게 선택하나요?',
    answer: '거의 없음(1.2): 사무직, 거의 운동하지 않음 / 가벼운 운동(1.375): 주 1~3일 가벼운 운동 / 보통(1.55): 주 3~5일 중간 강도 운동 / 활발(1.725): 주 6~7일 강도 높은 운동 / 매우 활발(1.9): 하루 2회 운동, 육체노동 종사자. 대부분의 직장인은 "거의 없음" 또는 "가벼운 운동"에 해당합니다.',
  },
  {
    question: '권장 영양소 비율은 어떻게 계산되나요?',
    answer: '탄수화물 50%, 단백질 30%, 지방 20% 비율로 계산합니다. 탄수화물·단백질은 1g당 4kcal, 지방은 1g당 9kcal이므로 목표 칼로리 기준으로 그램 수를 산출합니다. 예를 들어 2,000kcal 목표라면 탄수화물 250g, 단백질 150g, 지방 44g입니다. 개인 건강 상태에 따라 의료 전문가와 상담 후 조정하세요.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: '일일 칼로리 계산기',
  description,
  url: 'https://mycalcstool.com/calorie',
  applicationCategory: 'HealthApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'KRW' },
  inLanguage: 'ko',
};
---

<BaseLayout title={title} description={description} keywords={keywords} jsonLd={jsonLd}>
  <!-- 페이지 제목 -->
  <div class="mb-6">
    <nav class="text-sm text-gray-500 mb-2" aria-label="breadcrumb">
      <ol class="flex items-center gap-1 list-none p-0">
        <li><a href="/" class="hover:text-primary-600 transition-colors">홈</a></li>
        <li aria-hidden="true" class="text-gray-300">/</li>
        <li class="text-gray-700 font-medium" aria-current="page">일일 칼로리 계산기</li>
      </ol>
    </nav>
    <h1 class="text-2xl md:text-3xl font-bold text-gray-800">일일 칼로리 계산기</h1>
    <p class="text-gray-500 mt-2">Mifflin-St Jeor 공식 기반 기초대사량 · TDEE · 목표 칼로리</p>
  </div>

  <AdSlot slot="top" format="horizontal" />

  <!-- 입력 카드 -->
  <section class="card mb-6">
    <h2 class="section-title">신체 정보 입력</h2>

    <!-- 성별 -->
    <div class="mb-5">
      <p class="text-sm font-medium text-gray-700 mb-2">성별</p>
      <div class="flex gap-3">
        <label class="flex items-center gap-2 cursor-pointer">
          <input type="radio" name="gender" id="gender-male" value="male" checked
            class="w-4 h-4 text-primary-600 border-gray-300 focus:ring-primary-500" />
          <span class="text-sm text-gray-700">남성</span>
        </label>
        <label class="flex items-center gap-2 cursor-pointer">
          <input type="radio" name="gender" id="gender-female" value="female"
            class="w-4 h-4 text-primary-600 border-gray-300 focus:ring-primary-500" />
          <span class="text-sm text-gray-700">여성</span>
        </label>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-5">
      <!-- 나이 -->
      <div>
        <label for="age" class="block text-sm font-medium text-gray-700 mb-1">나이 <span class="text-gray-400 font-normal">(세)</span></label>
        <div class="flex items-center gap-3">
          <input type="number" id="age" min="10" max="100" value="30"
            class="input-field w-28" aria-describedby="age-range" />
          <input type="range" id="age-range" min="10" max="80" value="30"
            class="range-slider flex-1" aria-label="나이 슬라이더" />
        </div>
      </div>

      <!-- 키 -->
      <div>
        <label for="height" class="block text-sm font-medium text-gray-700 mb-1">키 <span class="text-gray-400 font-normal">(cm)</span></label>
        <div class="flex items-center gap-3">
          <input type="number" id="height" min="100" max="250" value="170"
            class="input-field w-28" aria-describedby="height-range" />
          <input type="range" id="height-range" min="130" max="220" value="170"
            class="range-slider flex-1" aria-label="키 슬라이더" />
        </div>
      </div>

      <!-- 몸무게 -->
      <div>
        <label for="weight" class="block text-sm font-medium text-gray-700 mb-1">몸무게 <span class="text-gray-400 font-normal">(kg)</span></label>
        <div class="flex items-center gap-3">
          <input type="number" id="weight" min="20" max="300" value="70"
            class="input-field w-28" aria-describedby="weight-range" />
          <input type="range" id="weight-range" min="30" max="150" value="70"
            class="range-slider flex-1" aria-label="몸무게 슬라이더" />
        </div>
      </div>
    </div>

    <!-- 활동량 -->
    <div class="mb-5">
      <label for="activity" class="block text-sm font-medium text-gray-700 mb-2">활동량</label>
      <select id="activity" class="input-field" aria-label="활동량 선택">
        <option value="1.2">거의 없음 — 사무직, 운동 안 함</option>
        <option value="1.375">가벼운 운동 — 주 1~3일 가벼운 운동</option>
        <option value="1.55" selected>보통 — 주 3~5일 중간 강도 운동</option>
        <option value="1.725">활발 — 주 6~7일 고강도 운동</option>
        <option value="1.9">매우 활발 — 하루 2회 운동 / 육체 노동</option>
      </select>
    </div>

    <!-- 목표 -->
    <div class="mb-6">
      <p class="text-sm font-medium text-gray-700 mb-2">목표</p>
      <div class="flex flex-wrap gap-3">
        <label class="flex items-center gap-2 cursor-pointer">
          <input type="radio" name="goal" id="goal-loss" value="loss" checked
            class="w-4 h-4 text-primary-600 border-gray-300 focus:ring-primary-500" />
          <span class="text-sm text-gray-700">체중 감량 <span class="text-gray-400">(-500kcal)</span></span>
        </label>
        <label class="flex items-center gap-2 cursor-pointer">
          <input type="radio" name="goal" id="goal-maintain" value="maintain"
            class="w-4 h-4 text-primary-600 border-gray-300 focus:ring-primary-500" />
          <span class="text-sm text-gray-700">체중 유지</span>
        </label>
        <label class="flex items-center gap-2 cursor-pointer">
          <input type="radio" name="goal" id="goal-gain" value="gain"
            class="w-4 h-4 text-primary-600 border-gray-300 focus:ring-primary-500" />
          <span class="text-sm text-gray-700">체중 증량 <span class="text-gray-400">(+300kcal)</span></span>
        </label>
      </div>
    </div>

    <button id="calc-btn" class="btn-primary w-full text-base py-3" type="button">
      칼로리 계산하기
    </button>
  </section>

  <!-- 결과 -->
  <section id="result-section" class="hidden mb-6" aria-live="polite">
    <AdSlot slot="result" format="rectangle" />

    <!-- BMR / TDEE 카드 -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
      <div class="card text-center border-2 border-gray-200">
        <p class="text-sm text-gray-500 mb-1">기초대사량 (BMR)</p>
        <p class="text-3xl font-bold tabular-nums text-gray-800" id="res-bmr">—</p>
        <p class="text-sm text-gray-400 mt-1">kcal / 일</p>
        <p class="text-xs text-gray-400 mt-2">생명 유지 최소 칼로리</p>
      </div>
      <div class="card text-center border-2 border-primary-200 bg-primary-50">
        <p class="text-sm text-primary-600 mb-1 font-medium">일일 소비 칼로리 (TDEE)</p>
        <p class="text-3xl font-bold tabular-nums text-primary-700" id="res-tdee">—</p>
        <p class="text-sm text-primary-400 mt-1">kcal / 일</p>
        <p class="text-xs text-primary-400 mt-2" id="res-activity-label">활동량 반영</p>
      </div>
    </div>

    <!-- 목표별 권장 칼로리 -->
    <div class="card mb-4">
      <h2 class="section-title">목표별 권장 섭취 칼로리</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
        <div id="goal-loss-card" class="p-4 rounded-xl border-2 text-center transition-colors">
          <p class="text-xs font-semibold uppercase tracking-wide mb-1" id="goal-loss-label">체중 감량</p>
          <p class="text-2xl font-bold tabular-nums" id="res-loss">—</p>
          <p class="text-xs mt-1 opacity-70">kcal / 일</p>
          <p class="text-xs mt-1 opacity-60">TDEE - 500kcal</p>
        </div>
        <div id="goal-maintain-card" class="p-4 rounded-xl border-2 text-center transition-colors">
          <p class="text-xs font-semibold uppercase tracking-wide mb-1">체중 유지</p>
          <p class="text-2xl font-bold tabular-nums" id="res-maintain">—</p>
          <p class="text-xs mt-1 opacity-70">kcal / 일</p>
          <p class="text-xs mt-1 opacity-60">TDEE 그대로</p>
        </div>
        <div id="goal-gain-card" class="p-4 rounded-xl border-2 text-center transition-colors">
          <p class="text-xs font-semibold uppercase tracking-wide mb-1">체중 증량</p>
          <p class="text-2xl font-bold tabular-nums" id="res-gain">—</p>
          <p class="text-xs mt-1 opacity-70">kcal / 일</p>
          <p class="text-xs mt-1 opacity-60">TDEE + 300kcal</p>
        </div>
      </div>
    </div>

    <!-- 권장 영양소 -->
    <div class="card mb-4">
      <h2 class="section-title">권장 영양소 섭취량</h2>
      <p class="text-xs text-gray-400 mb-4">목표 칼로리 기준 · 탄수화물 50% / 단백질 30% / 지방 20%</p>
      <div class="grid grid-cols-3 gap-4">
        <!-- 탄수화물 -->
        <div class="text-center">
          <div class="w-16 h-16 mx-auto rounded-full flex items-center justify-center mb-2"
               style="background: linear-gradient(135deg,#fde68a,#f59e0b)">
            <span class="text-xl font-bold text-white" aria-hidden="true">탄</span>
          </div>
          <p class="text-xs text-gray-500 font-medium">탄수화물</p>
          <p class="text-xl font-bold tabular-nums text-amber-600 mt-1" id="res-carb">—g</p>
          <p class="text-xs text-gray-400">50% · 4kcal/g</p>
        </div>
        <!-- 단백질 -->
        <div class="text-center">
          <div class="w-16 h-16 mx-auto rounded-full flex items-center justify-center mb-2"
               style="background: linear-gradient(135deg,#86efac,#16a34a)">
            <span class="text-xl font-bold text-white" aria-hidden="true">단</span>
          </div>
          <p class="text-xs text-gray-500 font-medium">단백질</p>
          <p class="text-xl font-bold tabular-nums text-green-600 mt-1" id="res-protein">—g</p>
          <p class="text-xs text-gray-400">30% · 4kcal/g</p>
        </div>
        <!-- 지방 -->
        <div class="text-center">
          <div class="w-16 h-16 mx-auto rounded-full flex items-center justify-center mb-2"
               style="background: linear-gradient(135deg,#93c5fd,#2563eb)">
            <span class="text-xl font-bold text-white" aria-hidden="true">지</span>
          </div>
          <p class="text-xs text-gray-500 font-medium">지방</p>
          <p class="text-xl font-bold tabular-nums text-blue-600 mt-1" id="res-fat">—g</p>
          <p class="text-xs text-gray-400">20% · 9kcal/g</p>
        </div>
      </div>

      <!-- 영양소 비율 바 -->
      <div class="mt-5">
        <div class="flex h-4 rounded-full overflow-hidden" role="img" aria-label="영양소 비율: 탄수화물 50%, 단백질 30%, 지방 20%">
          <div class="bg-amber-400" style="width:50%"></div>
          <div class="bg-green-500" style="width:30%"></div>
          <div class="bg-blue-500" style="width:20%"></div>
        </div>
        <div class="flex justify-between text-xs text-gray-500 mt-1">
          <span class="text-amber-600">탄수화물 50%</span>
          <span class="text-green-600">단백질 30%</span>
          <span class="text-blue-600">지방 20%</span>
        </div>
      </div>
    </div>

    <!-- 공식 안내 -->
    <div class="card bg-gray-50 border border-gray-100 mb-4">
      <h3 class="text-sm font-semibold text-gray-600 mb-2">계산 공식 (Mifflin-St Jeor)</h3>
      <div class="text-xs text-gray-500 space-y-1 font-mono">
        <p id="formula-line">남성 BMR = 10×체중 + 6.25×키 − 5×나이 − 5</p>
        <p>TDEE = BMR × 활동계수</p>
      </div>
    </div>
  </section>

  <AdSlot slot="content" format="rectangle" />

  <!-- SEO 콘텐츠 -->
  <section class="card mb-6">
    <h2 class="section-title">일일 칼로리 필요량이란?</h2>
    <div class="prose prose-sm text-gray-600 space-y-3">
      <p>
        <strong>기초대사량(BMR)</strong>은 아무것도 하지 않아도 심장 박동, 호흡, 체온 유지 등 생명 활동에 소모되는 최소 에너지입니다.
        여기에 일상 활동량을 반영하면 <strong>총 에너지 소비량(TDEE)</strong>이 됩니다.
        체중을 관리하려면 TDEE 대비 칼로리 섭취를 조절하는 것이 핵심입니다.
      </p>
      <p>
        <strong>Mifflin-St Jeor 공식</strong>은 1990년대 발표된 이후 영양학·의학 분야에서 가장 널리 사용되는 BMR 계산 공식입니다.
        해리스-베네딕트 공식보다 현대인의 신체 조성을 더 정확하게 반영하는 것으로 알려져 있습니다.
      </p>
      <p>
        단, 근육량이 많은 운동선수나 특정 질환이 있는 경우 실제 수치와 차이가 있을 수 있습니다.
        정밀한 측정이 필요하다면 의료기관에서 간접열량측정법(RMR)을 받아보시기 바랍니다.
      </p>
    </div>
  </section>

  <FAQ items={faqItems} />

  <!-- 관련 계산기 -->
  <section class="card mt-6">
    <h2 class="section-title">관련 계산기</h2>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
      {[
        { href: '/bmi', label: 'BMI 계산기', desc: '체질량지수 확인' },
        { href: '/tdee', label: '기초대사량 TDEE', desc: '활동별 소비 칼로리' },
        { href: '/due-date', label: '출산 예정일', desc: '임신 주수 계산' },
      ].map(l => (
        <a href={l.href} class="p-3 border border-gray-200 rounded-lg hover:border-primary-300 hover:bg-primary-50 transition-colors group">
          <div class="font-medium text-sm text-gray-700 group-hover:text-primary-600">{l.label}</div>
          <div class="text-xs text-gray-400 mt-0.5">{l.desc}</div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<script>
const ACTIVITY_LABELS: Record<string, string> = {
  '1.2':   '활동계수 1.2 (거의 없음)',
  '1.375': '활동계수 1.375 (가벼운 운동)',
  '1.55':  '활동계수 1.55 (보통)',
  '1.725': '활동계수 1.725 (활발)',
  '1.9':   '활동계수 1.9 (매우 활발)',
};

function fmt(n: number): string {
  return Math.round(n).toLocaleString('ko-KR');
}

function parseInputs() {
  const age    = parseInt((document.getElementById('age')    as HTMLInputElement).value, 10);
  const height = parseFloat((document.getElementById('height') as HTMLInputElement).value);
  const weight = parseFloat((document.getElementById('weight') as HTMLInputElement).value);
  const gender = (document.querySelector('input[name="gender"]:checked') as HTMLInputElement)?.value ?? 'male';
  const activity = parseFloat((document.getElementById('activity') as HTMLSelectElement).value);
  const goal   = (document.querySelector('input[name="goal"]:checked') as HTMLInputElement)?.value ?? 'loss';

  if (
    isNaN(age) || age < 10 || age > 100 ||
    isNaN(height) || height < 100 || height > 250 ||
    isNaN(weight) || weight < 20 || weight > 300 ||
    isNaN(activity)
  ) return null;

  return { age, height, weight, gender, activity, goal };
}

function calculate() {
  const inputs = parseInputs();
  if (!inputs) return;

  const { age, height, weight, gender, activity, goal } = inputs;

  // Mifflin-St Jeor
  const bmr = gender === 'male'
    ? 10 * weight + 6.25 * height - 5 * age - 5
    : 10 * weight + 6.25 * height - 5 * age - 161;

  const tdee  = bmr * activity;
  const loss  = tdee - 500;
  const maintain = tdee;
  const gain  = tdee + 300;

  const targetCal = goal === 'loss' ? loss : goal === 'gain' ? gain : maintain;

  // 영양소 (탄 50% / 단 30% / 지 20%)
  const carb    = (targetCal * 0.5) / 4;
  const protein = (targetCal * 0.3) / 4;
  const fat     = (targetCal * 0.2) / 9;

  // DOM 업데이트 (textContent only — XSS safe)
  setText('res-bmr', fmt(bmr));
  setText('res-tdee', fmt(tdee));
  setText('res-activity-label', ACTIVITY_LABELS[String(activity)] ?? '');
  setText('res-loss', fmt(loss));
  setText('res-maintain', fmt(maintain));
  setText('res-gain', fmt(gain));
  setText('res-carb', Math.round(carb) + 'g');
  setText('res-protein', Math.round(protein) + 'g');
  setText('res-fat', Math.round(fat) + 'g');

  // 공식 안내
  const formulaLine = gender === 'male'
    ? `남성 BMR = 10×${weight} + 6.25×${height} − 5×${age} − 5 = ${Math.round(bmr)}`
    : `여성 BMR = 10×${weight} + 6.25×${height} − 5×${age} − 161 = ${Math.round(bmr)}`;
  setText('formula-line', formulaLine);

  // 목표 카드 하이라이트
  highlightGoalCards(goal);

  // 결과 표시
  const section = document.getElementById('result-section');
  if (section) {
    section.classList.remove('hidden');
    section.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }
}

function setText(id: string, value: string) {
  const el = document.getElementById(id);
  if (el) el.textContent = value;
}

const GOAL_STYLES = {
  loss: {
    active:   'border-red-300 bg-red-50 text-red-600',
    inactive: 'border-gray-200 bg-white text-gray-600',
    label: '체중 감량',
  },
  maintain: {
    active:   'border-primary-300 bg-primary-50 text-primary-600',
    inactive: 'border-gray-200 bg-white text-gray-600',
    label: '체중 유지',
  },
  gain: {
    active:   'border-green-300 bg-green-50 text-green-600',
    inactive: 'border-gray-200 bg-white text-gray-600',
    label: '체중 증량',
  },
};

function highlightGoalCards(activeGoal: string) {
  (['loss', 'maintain', 'gain'] as const).forEach(g => {
    const card = document.getElementById(`goal-${g}-card`);
    if (!card) return;
    const styles = GOAL_STYLES[g];
    card.className = `p-4 rounded-xl border-2 text-center transition-colors ${
      g === activeGoal ? styles.active : styles.inactive
    }`;
  });
}

// 슬라이더 ↔ 숫자 입력 동기화
function syncPair(numId: string, rangeId: string) {
  const num   = document.getElementById(numId)   as HTMLInputElement;
  const range = document.getElementById(rangeId) as HTMLInputElement;
  if (!num || !range) return;
  num.addEventListener('input', () => {
    const v = parseFloat(num.value);
    if (!isNaN(v)) range.value = String(Math.min(Math.max(v, parseFloat(range.min)), parseFloat(range.max)));
  });
  range.addEventListener('input', () => { num.value = range.value; });
}

document.addEventListener('DOMContentLoaded', () => {
  syncPair('age', 'age-range');
  syncPair('height', 'height-range');
  syncPair('weight', 'weight-range');

  document.getElementById('calc-btn')?.addEventListener('click', calculate);

  // 라디오 변경 시 결과가 표시된 상태면 자동 재계산
  document.querySelectorAll('input[name="gender"], input[name="goal"]').forEach(el => {
    el.addEventListener('change', () => {
      const section = document.getElementById('result-section');
      if (section && !section.classList.contains('hidden')) calculate();
    });
  });

  // 초기 계산 (기본값)
  calculate();
});
</script>

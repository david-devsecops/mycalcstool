---
import BaseLayout from '../layouts/BaseLayout.astro';
import AdSlot from '../components/AdSlot.astro';
import FAQ from '../components/FAQ.astro';

const title = '2026 대출 이자 계산기 - 원리금균등·원금균등·만기일시 비교';
const description = '대출금액, 금리, 기간을 입력하면 원리금균등, 원금균등, 만기일시 3가지 상환 방식을 한눈에 비교합니다. 월 상환금, 총 이자, 상환 스케줄까지 무료로 확인하세요.';
const keywords = '대출 이자 계산기, 주택담보대출 계산기, 대출 상환 계산기, 원리금균등상환, 원금균등상환, 만기일시상환, 대출 이자 비교, 모기지 계산기, 대출 상환 스케줄';

const faqItems = [
  {
    question: '원리금균등상환과 원금균등상환 중 어떤 게 유리한가요?',
    answer: '총 이자 절약 측면에서는 원금균등상환이 유리합니다. 원금균등은 매달 원금을 동일하게 갚으므로 잔액이 빠르게 줄어 이자 부담이 적습니다. 다만 초기 상환금이 원리금균등보다 높아 자금 여유가 필요합니다. 초기에 여유 자금이 있다면 원금균등, 매달 일정한 금액을 납부하고 싶다면 원리금균등을 선택하세요.',
  },
  {
    question: '중도상환하면 이자가 줄어드나요?',
    answer: '네, 중도상환 시 남은 원금이 줄어들어 이후 이자 부담이 크게 감소합니다. 다만 많은 금융기관에서 대출 후 3년 이내 중도상환 시 중도상환수수료(통상 대출잔액의 1~2%)를 부과합니다. 중도상환 전 수수료와 이자 절약액을 비교해보시기 바랍니다.',
  },
  {
    question: '거치기간이란 무엇인가요?',
    answer: '거치기간(이자만 납부 기간)은 대출 초기 일정 기간 동안 원금 상환 없이 이자만 납부하는 기간입니다. 이 기간에는 월 부담이 줄어드는 장점이 있지만, 원금이 줄지 않아 총 이자 부담은 증가합니다. 주로 주택담보대출이나 전세대출에서 활용됩니다.',
  },
];

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: '대출 이자 계산기',
    description,
    url: 'https://mycalcstool.com/loan',
    applicationCategory: 'FinanceApplication',
    operatingSystem: 'All',
    offers: {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'KRW',
    },
    inLanguage: 'ko',
  },
];
---

<BaseLayout title={title} description={description} keywords={keywords} jsonLd={jsonLd} hreflangEn="/en/mortgage-calculator">
  <!-- 페이지 제목 -->
  <div class="mb-6">
    <nav class="text-sm text-gray-500 mb-2" aria-label="breadcrumb">
      <ol class="flex items-center gap-1 list-none p-0">
        <li><a href="/" class="hover:text-primary-600 transition-colors">홈</a></li>
        <li aria-hidden="true" class="text-gray-300">/</li>
        <li class="text-gray-700 font-medium" aria-current="page">대출 이자 계산기</li>
      </ol>
    </nav>
    <h1 class="text-2xl md:text-3xl font-bold text-gray-800">
      🏦 대출 이자 계산기
    </h1>
    <p class="text-gray-500 mt-2">
      3가지 상환 방식(원리금균등·원금균등·만기일시)을 한눈에 비교하세요
    </p>
  </div>

  <!-- 상단 광고 -->
  <AdSlot slot="top" format="horizontal" />

  <!-- 입력 폼 -->
  <section class="card mb-6" aria-labelledby="input-section">
    <h2 class="section-title" id="input-section">
      <span aria-hidden="true">📝</span>
      대출 정보 입력
    </h2>

    <div class="space-y-6">
      <!-- 대출 금액 -->
      <div>
        <label for="loan-amount" class="block text-sm font-semibold text-gray-700 mb-2">
          대출 금액
        </label>
        <div class="flex items-center gap-3">
          <input
            type="number"
            id="loan-amount"
            class="input-field flex-1"
            value="10000"
            min="100"
            max="500000"
            step="100"
            aria-describedby="loan-amount-desc"
            inputmode="numeric"
          />
          <span class="text-gray-600 font-medium whitespace-nowrap">만원</span>
        </div>
        <input
          type="range"
          id="loan-amount-slider"
          class="range-slider mt-2"
          min="100"
          max="200000"
          step="100"
          value="10000"
          aria-label="대출 금액 슬라이더"
        />
        <p id="loan-amount-desc" class="text-xs text-gray-400 mt-1">100만원 ~ 200,000만원</p>
      </div>

      <!-- 연 이자율 -->
      <div>
        <label for="interest-rate" class="block text-sm font-semibold text-gray-700 mb-2">
          연 이자율
        </label>
        <div class="flex items-center gap-3">
          <input
            type="number"
            id="interest-rate"
            class="input-field flex-1"
            value="3.5"
            min="0.1"
            max="30"
            step="0.1"
            aria-describedby="interest-rate-desc"
            inputmode="decimal"
          />
          <span class="text-gray-600 font-medium">%</span>
        </div>
        <input
          type="range"
          id="interest-rate-slider"
          class="range-slider mt-2"
          min="0.1"
          max="20"
          step="0.1"
          value="3.5"
          aria-label="이자율 슬라이더"
        />
        <p id="interest-rate-desc" class="text-xs text-gray-400 mt-1">0.1% ~ 30%</p>
      </div>

      <!-- 대출 기간 -->
      <div>
        <label for="loan-period" class="block text-sm font-semibold text-gray-700 mb-2">
          대출 기간
        </label>
        <div class="flex items-center gap-3">
          <input
            type="number"
            id="loan-period"
            class="input-field flex-1"
            value="30"
            min="1"
            max="50"
            step="1"
            aria-describedby="loan-period-desc"
            inputmode="numeric"
          />
          <span class="text-gray-600 font-medium">년</span>
        </div>
        <input
          type="range"
          id="loan-period-slider"
          class="range-slider mt-2"
          min="1"
          max="50"
          step="1"
          value="30"
          aria-label="대출 기간 슬라이더"
        />
        <!-- 빠른 선택 버튼 -->
        <div class="flex gap-2 mt-2">
          {[10, 20, 30, 40].map(year => (
            <button
              class="period-btn px-3 py-1 text-sm rounded-lg border border-gray-300 text-gray-600 hover:border-primary-400 hover:text-primary-600 transition-colors"
              data-year={year}
              type="button"
              aria-label={`대출기간 ${year}년`}
            >
              {year}년
            </button>
          ))}
        </div>
        <p id="loan-period-desc" class="text-xs text-gray-400 mt-1">1년 ~ 50년</p>
      </div>

      <!-- 거치 기간 -->
      <div>
        <label for="grace-period" class="block text-sm font-semibold text-gray-700 mb-2">
          거치 기간 <span class="text-gray-400 font-normal">(선택사항)</span>
        </label>
        <div class="flex items-center gap-3">
          <input
            type="number"
            id="grace-period"
            class="input-field flex-1"
            value="0"
            min="0"
            max="10"
            step="1"
            aria-describedby="grace-period-desc"
            inputmode="numeric"
          />
          <span class="text-gray-600 font-medium">년</span>
        </div>
        <p id="grace-period-desc" class="text-xs text-gray-400 mt-1">0년 = 거치기간 없음 (바로 원금 상환)</p>
      </div>

      <!-- 계산 버튼 -->
      <button id="calculate-btn" class="btn-primary" type="button">
        🔍 계산하기
      </button>
    </div>
  </section>

  <!-- 결과 영역 (초기에는 숨김) -->
  <div id="results-section" class="hidden" aria-live="polite" aria-atomic="true">

    <!-- 3가지 상환 방식 비교 카드 -->
    <section class="card mb-6" aria-labelledby="comparison-title">
      <h2 class="section-title" id="comparison-title">
        <span aria-hidden="true">📊</span>
        3가지 상환 방식 비교
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">

        <!-- 원리금균등 -->
        <div class="bg-blue-50 border border-blue-200 rounded-xl p-5">
          <div class="flex items-center gap-2 mb-3">
            <span class="text-2xl" aria-hidden="true">⭐</span>
            <h3 class="font-bold text-blue-800">원리금균등상환</h3>
          </div>
          <dl class="space-y-2">
            <div>
              <dt class="text-xs text-blue-600">월 상환금</dt>
              <dd class="result-number text-blue-700" id="equal-payment-monthly">-</dd>
              <dd class="text-xs text-blue-600">원</dd>
            </div>
            <div class="pt-2 border-t border-blue-200">
              <dt class="text-xs text-gray-600">총 이자</dt>
              <dd class="text-lg font-bold tabular-nums text-gray-700" id="equal-payment-interest">-</dd>
              <dd class="text-xs text-gray-600">원</dd>
            </div>
            <div>
              <dt class="text-xs text-gray-600">총 상환금</dt>
              <dd class="text-lg font-bold tabular-nums text-gray-700" id="equal-payment-total">-</dd>
              <dd class="text-xs text-gray-600">원</dd>
            </div>
          </dl>
          <p class="text-xs text-blue-600 mt-3 font-medium">매달 동일한 금액 납부 · 계획적 자금 관리</p>
        </div>

        <!-- 원금균등 -->
        <div class="bg-green-50 border border-green-200 rounded-xl p-5">
          <div class="flex items-center gap-2 mb-3">
            <span class="text-2xl" aria-hidden="true">💰</span>
            <h3 class="font-bold text-green-800">원금균등상환</h3>
          </div>
          <dl class="space-y-2">
            <div>
              <dt class="text-xs text-green-600">첫달 상환금</dt>
              <dd class="result-number text-green-700" id="equal-principal-first">-</dd>
              <dd class="text-xs text-green-600">원</dd>
            </div>
            <div class="pt-2 border-t border-green-200">
              <dt class="text-xs text-gray-600">총 이자</dt>
              <dd class="text-lg font-bold tabular-nums text-gray-700" id="equal-principal-interest">-</dd>
              <dd class="text-xs text-gray-600">원</dd>
            </div>
            <div>
              <dt class="text-xs text-gray-600">총 상환금</dt>
              <dd class="text-lg font-bold tabular-nums text-gray-700" id="equal-principal-total">-</dd>
              <dd class="text-xs text-gray-600">원</dd>
            </div>
          </dl>
          <p class="text-xs text-green-600 mt-3 font-medium">이자 절약 최대 · 초기 부담 높음</p>
        </div>

        <!-- 만기일시 -->
        <div class="bg-red-50 border border-red-200 rounded-xl p-5">
          <div class="flex items-center gap-2 mb-3">
            <span class="text-2xl" aria-hidden="true">⚠️</span>
            <h3 class="font-bold text-red-800">만기일시상환</h3>
          </div>
          <dl class="space-y-2">
            <div>
              <dt class="text-xs text-red-600">월 이자</dt>
              <dd class="result-number text-red-700" id="bullet-monthly">-</dd>
              <dd class="text-xs text-red-600">원</dd>
            </div>
            <div class="pt-2 border-t border-red-200">
              <dt class="text-xs text-gray-600">총 이자</dt>
              <dd class="text-lg font-bold tabular-nums text-gray-700" id="bullet-interest">-</dd>
              <dd class="text-xs text-gray-600">원</dd>
            </div>
            <div>
              <dt class="text-xs text-gray-600">총 상환금</dt>
              <dd class="text-lg font-bold tabular-nums text-gray-700" id="bullet-total">-</dd>
              <dd class="text-xs text-gray-600">원</dd>
            </div>
          </dl>
          <p class="text-xs text-red-600 mt-3 font-medium">이자 부담 가장 높음 · 만기에 원금 일시 납부</p>
        </div>
      </div>

      <!-- 이자 절약 비교 메시지 -->
      <div id="saving-message" class="mt-4 p-4 bg-success/10 border border-green-200 rounded-lg text-sm text-green-700 font-medium text-center hidden">
      </div>
    </section>

    <!-- 결과 광고 -->
    <AdSlot slot="result" format="rectangle" />

    <!-- 이자 비교 차트 -->
    <section class="card mb-6" aria-labelledby="chart-title">
      <h2 class="section-title" id="chart-title">
        <span aria-hidden="true">📈</span>
        총 이자 비교 차트
      </h2>
      <div class="relative h-40 sm:h-48 md:h-52">
        <canvas id="interest-chart" aria-label="총 이자 비교 바 차트" role="img"></canvas>
      </div>
    </section>

    <!-- 월별 상환 스케줄 -->
    <section class="card mb-6" aria-labelledby="schedule-title">
      <div class="flex items-center justify-between mb-4">
        <h2 class="section-title mb-0" id="schedule-title">
          <span aria-hidden="true">📋</span>
          월별 상환 스케줄
        </h2>
        <div>
          <label for="schedule-type" class="sr-only">상환 방식 선택</label>
          <select id="schedule-type" class="text-sm border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-primary-500">
            <option value="equal-payment">원리금균등</option>
            <option value="equal-principal">원금균등</option>
            <option value="bullet">만기일시</option>
          </select>
        </div>
      </div>

      <div class="overflow-x-auto -mx-6 px-6">
        <table class="w-full text-sm" aria-label="월별 상환 스케줄">
          <thead>
            <tr class="bg-gray-50 text-gray-600">
              <th scope="col" class="px-3 py-2 text-left font-semibold">회차</th>
              <th scope="col" class="px-3 py-2 text-right font-semibold">원금</th>
              <th scope="col" class="px-3 py-2 text-right font-semibold">이자</th>
              <th scope="col" class="px-3 py-2 text-right font-semibold">월 납입금</th>
              <th scope="col" class="px-3 py-2 text-right font-semibold">남은 잔액</th>
            </tr>
          </thead>
          <tbody id="schedule-tbody" class="divide-y divide-gray-100">
          </tbody>
        </table>
      </div>

      <div class="mt-4 flex justify-center">
        <button id="toggle-schedule" class="text-sm text-primary-600 hover:text-primary-700 font-medium border border-primary-300 rounded-lg px-4 py-2 hover:bg-primary-50 transition-colors" type="button">
          전체 보기 ▼
        </button>
      </div>
    </section>

    <!-- 콘텐츠 광고 -->
    <AdSlot slot="content" format="rectangle" />

    <section id="share-section" class="card mt-6 hidden" aria-labelledby="share-title">
      <h2 class="section-title" id="share-title">
        <span aria-hidden="true">🔗</span>
        계산 결과 공유
      </h2>
      <div class="flex flex-col md:flex-row md:items-center gap-3">
        <p class="text-sm text-gray-600 flex-1">현재 입력값을 포함한 링크를 복사해 상담, 가족 공유, 메모용으로 활용할 수 있습니다.</p>
        <button id="copy-share-link" class="btn-primary md:w-auto" type="button">링크 복사</button>
      </div>
      <p id="share-feedback" class="text-xs text-gray-400 mt-2"></p>
    </section>
  </div>

  <!-- SEO 콘텐츠 -->
  <section class="card mb-6">
    <h2 class="section-title">
      <span aria-hidden="true">📖</span>
      대출 상환 방식 가이드
    </h2>
    <div class="prose prose-sm max-w-none text-gray-700 space-y-4 leading-relaxed">
      <p>
        대출을 받을 때 상환 방식 선택은 총 이자 비용에 큰 영향을 미칩니다.
        동일한 대출 조건이라도 상환 방식에 따라 총 이자 부담이 수백만 원에서 수천만 원까지 차이가 날 수 있습니다.
      </p>

      <h3 class="text-lg font-bold text-gray-800">원리금균등상환이란?</h3>
      <p>
        원리금균등상환은 매달 동일한 금액(원금 + 이자)을 납부하는 방식입니다.
        상환 초기에는 이자 비중이 높고, 후반부로 갈수록 원금 비중이 높아집니다.
        가장 일반적인 대출 상환 방식으로, 월 지출을 예측하기 쉬운 장점이 있습니다.
      </p>

      <h3 class="text-lg font-bold text-gray-800">원금균등상환이란?</h3>
      <p>
        원금균등상환은 매달 동일한 원금을 납부하고, 이자는 남은 원금에 따라 줄어드는 방식입니다.
        초기 상환 부담이 크지만, 시간이 지날수록 월 납부금이 줄어듭니다.
        총 이자 비용이 가장 적어 장기적으로 가장 경제적입니다.
      </p>

      <h3 class="text-lg font-bold text-gray-800">만기일시상환이란?</h3>
      <p>
        만기일시상환은 대출 기간 동안 매달 이자만 납부하고, 만기에 원금 전액을 한 번에 상환하는 방식입니다.
        월 납부 부담이 가장 적지만, 원금이 줄지 않아 총 이자 부담이 가장 큽니다.
        주로 단기 대출이나 전세자금 대출에 활용됩니다.
      </p>

      <h3 class="text-lg font-bold text-gray-800">어떤 방식이 유리할까?</h3>
      <p>
        총 이자 절약을 원한다면 <strong>원금균등상환</strong>이 최선입니다.
        매달 일정한 금액으로 계획적인 자금 관리를 원한다면 <strong>원리금균등상환</strong>을 추천합니다.
        초기 자금 여유가 있고 장기 대출을 계획한다면, 원금균등으로 시작해 재정 상황에 따라 조기 상환을 고려하세요.
      </p>
    </div>
  </section>

  <!-- FAQ -->
  <FAQ items={faqItems} />

  <section class="card mt-6">
    <h2 class="section-title">
      <span aria-hidden="true">🛡️</span>
      계산 기준 및 문의
    </h2>
    <div class="space-y-3 text-sm text-gray-700">

<!-- Chart.js CDN (defer로 성능 최적화) -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js" defer></script>

<script>
// ============================================================
// 대출 이자 계산기 - 순수 JavaScript
// 보안: 모든 입력값 검증 후 처리, eval() 미사용
// ============================================================

/** 숫자 형식화 (천 단위 콤마) */
function formatNumber(num: number): string {
  return Math.round(num).toLocaleString('ko-KR');
}

/** 만원 단위를 원 단위로 변환 */
function manToWon(man: number): number {
  return man * 10000;
}

/** 입력값 검증 및 파싱 */
function parseInputs(): { amount: number; rate: number; period: number; grace: number } | null {
  const amountEl = document.getElementById('loan-amount') as HTMLInputElement;
  const rateEl = document.getElementById('interest-rate') as HTMLInputElement;
  const periodEl = document.getElementById('loan-period') as HTMLInputElement;
  const graceEl = document.getElementById('grace-period') as HTMLInputElement;

  const amount = parseFloat(amountEl?.value || '0');
  const rate = parseFloat(rateEl?.value || '0');
  const period = parseInt(periodEl?.value || '0', 10);
  const grace = parseInt(graceEl?.value || '0', 10);

  // 입력값 검증 (보안: 범위 확인)
  if (isNaN(amount) || amount < 100 || amount > 500000) {
    alert('대출 금액을 올바르게 입력해주세요. (100만원 ~ 500,000만원)');
    return null;
  }
  if (isNaN(rate) || rate < 0.1 || rate > 30) {
    alert('이자율을 올바르게 입력해주세요. (0.1% ~ 30%)');
    return null;
  }
  if (isNaN(period) || period < 1 || period > 50) {
    alert('대출 기간을 올바르게 입력해주세요. (1년 ~ 50년)');
    return null;
  }
  if (isNaN(grace) || grace < 0 || grace >= period) {
    alert('거치 기간은 대출 기간보다 짧아야 합니다.');
    return null;
  }

  return { amount, rate, period, grace };
}

/** 원리금균등상환 계산 */
function calculateEqualPayment(
  principal: number,
  monthlyRate: number,
  totalMonths: number
): { monthly: number; schedule: Array<{ principal: number; interest: number; payment: number; balance: number }> } {
  if (monthlyRate === 0) {
    const monthly = principal / totalMonths;
    const schedule = Array.from({ length: totalMonths }, (_, i) => ({
      principal: monthly,
      interest: 0,
      payment: monthly,
      balance: principal - monthly * (i + 1),
    }));
    return { monthly, schedule };
  }

  const monthly = principal * monthlyRate * Math.pow(1 + monthlyRate, totalMonths) /
    (Math.pow(1 + monthlyRate, totalMonths) - 1);

  const schedule = [];
  let balance = principal;

  for (let i = 0; i < totalMonths; i++) {
    const interest = balance * monthlyRate;
    const principalPayment = monthly - interest;
    balance = Math.max(0, balance - principalPayment);
    schedule.push({ principal: principalPayment, interest, payment: monthly, balance });
  }

  return { monthly, schedule };
}

/** 원금균등상환 계산 */
function calculateEqualPrincipal(
  principal: number,
  monthlyRate: number,
  totalMonths: number
): { firstPayment: number; schedule: Array<{ principal: number; interest: number; payment: number; balance: number }> } {
  const principalPayment = principal / totalMonths;
  const schedule = [];
  let balance = principal;

  for (let i = 0; i < totalMonths; i++) {
    const interest = balance * monthlyRate;
    const payment = principalPayment + interest;
    balance = Math.max(0, balance - principalPayment);
    schedule.push({ principal: principalPayment, interest, payment, balance });
  }

  return { firstPayment: schedule[0]?.payment || 0, schedule };
}

/** 만기일시상환 계산 */
function calculateBullet(
  principal: number,
  monthlyRate: number,
  totalMonths: number
): { monthly: number; schedule: Array<{ principal: number; interest: number; payment: number; balance: number }> } {
  const monthlyInterest = principal * monthlyRate;
  const schedule = Array.from({ length: totalMonths }, (_, i) => ({
    principal: i === totalMonths - 1 ? principal : 0,
    interest: monthlyInterest,
    payment: i === totalMonths - 1 ? principal + monthlyInterest : monthlyInterest,
    balance: i === totalMonths - 1 ? 0 : principal,
  }));
  return { monthly: monthlyInterest, schedule };
}

// 전역 상태 (계산 결과 저장)
let schedules: Record<string, Array<{ principal: number; interest: number; payment: number; balance: number }>> = {};
let showFullSchedule = false;
let chartInstance: any = null;

function applyQueryParams(): void {
  const params = new URLSearchParams(window.location.search);
  const amount = params.get('amount');
  const rate = params.get('rate');
  const period = params.get('period');
  const grace = params.get('grace');

  const setValue = (id: string, value: string | null) => {
    if (!value) return;
    const el = document.getElementById(id) as HTMLInputElement | null;
    if (el) el.value = value;
  };

  setValue('loan-amount', amount);
  setValue('loan-amount-slider', amount);
  setValue('interest-rate', rate);
  setValue('interest-rate-slider', rate);
  setValue('loan-period', period);
  setValue('loan-period-slider', period);
  setValue('grace-period', grace);
}

function updateShareLink(amount: number, rate: number, period: number, grace: number): void {
  const shareSection = document.getElementById('share-section');
  const copyButton = document.getElementById('copy-share-link') as HTMLButtonElement | null;
  const feedback = document.getElementById('share-feedback');
  const url = new URL(window.location.href);
  url.search = '';
  url.searchParams.set('amount', String(amount));
  url.searchParams.set('rate', String(rate));
  url.searchParams.set('period', String(period));
  url.searchParams.set('grace', String(grace));

  if (copyButton) {
    copyButton.dataset.shareUrl = url.toString();
  }
  if (feedback) {
    feedback.textContent = `${amount.toLocaleString('ko-KR')}만원 · ${rate}% · ${period}년 · 거치 ${grace}년`;
  }
  shareSection?.classList.remove('hidden');
}

async function copyShareLink(): Promise<void> {
  const copyButton = document.getElementById('copy-share-link') as HTMLButtonElement | null;
  const feedback = document.getElementById('share-feedback');
  const shareUrl = copyButton?.dataset.shareUrl;
  if (!shareUrl) return;

  try {
    await navigator.clipboard.writeText(shareUrl);
    if (feedback) feedback.textContent = '공유 링크를 복사했습니다.';
  } catch {
    if (feedback) feedback.textContent = shareUrl;
  }
}

/** 스케줄 테이블 렌더링 */
function renderSchedule(type: string): void {
  const tbody = document.getElementById('schedule-tbody');
  if (!tbody || !schedules[type]) return;

  const data = schedules[type];
  const displayCount = showFullSchedule ? data.length : Math.min(12, data.length);

  // XSS 방지: innerHTML 대신 DOM API 사용
  tbody.innerHTML = '';

  for (let i = 0; i < displayCount; i++) {
    const row = data[i];
    const tr = document.createElement('tr');
    tr.className = i % 2 === 0 ? 'bg-white' : 'bg-gray-50';

    const cellTexts = [
      `${i + 1}회`,
      `${formatNumber(row.principal)}원`,
      `${formatNumber(row.interest)}원`,
      `${formatNumber(row.payment)}원`,
      `${formatNumber(row.balance)}원`,
    ];

    cellTexts.forEach((text, idx) => {
      const td = document.createElement('td');
      td.className = idx === 0
        ? 'px-3 py-2 text-left text-gray-500'
        : 'px-3 py-2 text-right tabular-nums text-gray-700';
      td.textContent = text; // XSS 안전: textContent 사용
      tr.appendChild(td);
    });

    tbody.appendChild(tr);
  }

  // 전체 보기 버튼
  const toggleBtn = document.getElementById('toggle-schedule');
  if (toggleBtn) {
    if (data.length <= 12) {
      toggleBtn.classList.add('hidden');
    } else {
      toggleBtn.classList.remove('hidden');
      toggleBtn.textContent = showFullSchedule ? '접기 ▲' : `전체 보기 (${data.length}개월) ▼`;
    }
  }
}

/** 메인 계산 함수 */
function calculate(): void {
  const inputs = parseInputs();
  if (!inputs) return;

  const { amount, rate, period, grace } = inputs;
  const principal = manToWon(amount);
  const monthlyRate = rate / 100 / 12;
  const totalMonths = period * 12;
  const graceMonths = grace * 12;
  const repayMonths = totalMonths - graceMonths;

  // 거치기간 처리
  const effectivePrincipal = principal;
  const graceInterest = graceMonths > 0 ? principal * monthlyRate * graceMonths : 0;

  // 각 상환 방식 계산
  const ep = calculateEqualPayment(effectivePrincipal, monthlyRate, repayMonths);
  const epr = calculateEqualPrincipal(effectivePrincipal, monthlyRate, repayMonths);
  const bullet = calculateBullet(effectivePrincipal, monthlyRate, totalMonths);

  const epTotalInterest = ep.schedule.reduce((sum, r) => sum + r.interest, 0) + graceInterest;
  const eprTotalInterest = epr.schedule.reduce((sum, r) => sum + r.interest, 0) + graceInterest;
  const bulletTotalInterest = bullet.schedule.reduce((sum, r) => sum + r.interest, 0);

  // 스케줄 저장
  schedules = {
    'equal-payment': ep.schedule,
    'equal-principal': epr.schedule,
    'bullet': bullet.schedule,
  };

  // UI 업데이트 (XSS 안전: textContent 사용)
  const setText = (id: string, value: string) => {
    const el = document.getElementById(id);
    if (el) el.textContent = value;
  };

  setText('equal-payment-monthly', formatNumber(ep.monthly));
  setText('equal-payment-interest', formatNumber(epTotalInterest));
  setText('equal-payment-total', formatNumber(principal + epTotalInterest));

  setText('equal-principal-first', formatNumber(epr.firstPayment));
  setText('equal-principal-interest', formatNumber(eprTotalInterest));
  setText('equal-principal-total', formatNumber(principal + eprTotalInterest));

  setText('bullet-monthly', formatNumber(bullet.monthly));
  setText('bullet-interest', formatNumber(bulletTotalInterest));
  setText('bullet-total', formatNumber(principal + bulletTotalInterest));

  // 이자 절약 메시지
  const saving = epTotalInterest - eprTotalInterest;
  const savingMsg = document.getElementById('saving-message');
  if (savingMsg && saving > 0) {
    savingMsg.textContent = `💡 원금균등이 원리금균등 대비 ${formatNumber(saving)}원 이자 절약!`;
    savingMsg.classList.remove('hidden');
  }

  // 차트 업데이트
  updateChart(epTotalInterest, eprTotalInterest, bulletTotalInterest);

  // 스케줄 렌더링
  showFullSchedule = false;
  renderSchedule('equal-payment');
  updateShareLink(amount, rate, period, grace);

  // 결과 영역 표시
  const resultsSection = document.getElementById('results-section');
  if (resultsSection) {
    resultsSection.classList.remove('hidden');
    resultsSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }
}

/** 차트 업데이트 */
function updateChart(epInterest: number, eprInterest: number, bulletInterest: number): void {
  const canvas = document.getElementById('interest-chart') as HTMLCanvasElement;
  if (!canvas) return;

  // Chart.js 로드 대기
  const tryUpdateChart = () => {
    if (typeof window === 'undefined' || !(window as any).Chart) {
      setTimeout(tryUpdateChart, 100);
      return;
    }

    const Chart = (window as any).Chart;

    if (chartInstance) {
      chartInstance.destroy();
    }

    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    chartInstance = new Chart(ctx, {
      type: 'bar',
      data: {
        labels: ['원리금균등', '원금균등', '만기일시'],
        datasets: [{
          label: '총 이자 (원)',
          data: [Math.round(epInterest), Math.round(eprInterest), Math.round(bulletInterest)],
          backgroundColor: ['rgba(59, 130, 246, 0.7)', 'rgba(16, 185, 129, 0.7)', 'rgba(239, 68, 68, 0.7)'],
          borderColor: ['#2563EB', '#059669', '#DC2626'],
          borderWidth: 2,
          borderRadius: 6,
        }],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              label: (context: any) => `총 이자: ${formatNumber(context.raw)}원`,
            },
          },
        },
        scales: {
          y: {
            beginAtZero: true,
            ticks: {
              callback: (value: number) => `${formatNumber(value)}원`,
              maxTicksLimit: 5,
            },
            grid: { color: 'rgba(0,0,0,0.05)' },
          },
          x: {
            grid: { display: false },
          },
        },
      },
    });
  };

  tryUpdateChart();
}

/** 슬라이더 ↔ 입력 연동 설정 */
function setupSliderSync(inputId: string, sliderId: string): void {
  const input = document.getElementById(inputId) as HTMLInputElement;
  const slider = document.getElementById(sliderId) as HTMLInputElement;
  if (!input || !slider) return;

  input.addEventListener('input', () => {
    const val = parseFloat(input.value);
    if (!isNaN(val)) slider.value = String(val);
  });

  slider.addEventListener('input', () => {
    input.value = slider.value;
  });
}

/** 이벤트 리스너 초기화 */
document.addEventListener('DOMContentLoaded', () => {
  applyQueryParams();
  // 슬라이더 연동
  setupSliderSync('loan-amount', 'loan-amount-slider');
  setupSliderSync('interest-rate', 'interest-rate-slider');
  setupSliderSync('loan-period', 'loan-period-slider');

  // 기간 빠른 선택
  document.querySelectorAll('.period-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const year = (btn as HTMLElement).dataset.year;
      const input = document.getElementById('loan-period') as HTMLInputElement;
      const slider = document.getElementById('loan-period-slider') as HTMLInputElement;
      if (input && slider && year) {
        input.value = year;
        slider.value = year;
      }
    });
  });

  // 계산 버튼
  const calcBtn = document.getElementById('calculate-btn');
  if (calcBtn) calcBtn.addEventListener('click', calculate);

  // Enter 키로 계산
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && (e.target as HTMLElement)?.closest?.('.card')) {
      calculate();
    }
  });

  // 스케줄 타입 변경
  const scheduleSelect = document.getElementById('schedule-type') as HTMLSelectElement;
  if (scheduleSelect) {
    scheduleSelect.addEventListener('change', () => {
      showFullSchedule = false;
      renderSchedule(scheduleSelect.value);
    });
  }

  // 전체 보기 토글
  const toggleBtn = document.getElementById('toggle-schedule');
  if (toggleBtn) {
    toggleBtn.addEventListener('click', () => {
      showFullSchedule = !showFullSchedule;
      const scheduleSelect = document.getElementById('schedule-type') as HTMLSelectElement;
      renderSchedule(scheduleSelect?.value || 'equal-payment');
    });
  }

  document.getElementById('copy-share-link')?.addEventListener('click', () => {
    copyShareLink();
  });

  // 초기 계산 실행 (기본값으로)
  calculate();
});
</script>

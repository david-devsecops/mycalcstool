---
import BaseLayout from '../layouts/BaseLayout.astro';
import siteConfig from '../data/site-config.json';
import { siteMeta } from '../data/site-meta';

const title = '사이트 소개 - mycalcstool';
const description = 'mycalcstool 운영 원칙, 계산기 운영 범위, 계산 기준, 문의 경로를 안내합니다.';

const flagshipCalculators = siteConfig.calculators.filter((calculator) => calculator.category === '금융').slice(0, 5);
---

<BaseLayout title={title} description={description} hreflangEn="/en/about">
  <div class="space-y-6">
    <section class="card">
      <h1 class="text-2xl font-bold text-gray-800 mb-4">mycalcstool 소개</h1>
      <p class="text-gray-600 leading-relaxed">
        {siteMeta.name}은 실생활 계산 도구를 제공하는 정적 웹사이트입니다. 현재는
        <strong class="text-gray-800"> 금융 계산기와 세후 금액·상환 계획처럼 의사결정에 직접 연결되는 계산기</strong>를
        우선 강화하고, 건강·생활 계산기는 보조 도구로 운영합니다.
      </p>
      <p class="text-gray-600 leading-relaxed mt-3">
        모든 계산은 브라우저에서 실행되며, 입력값은 서버에 저장하지 않습니다. 중요한 금융·세무·의료 판단은
        반드시 공식 기관이나 전문가와 교차 확인해야 합니다.
      </p>
    </section>

    <section class="card">
      <h2 class="text-xl font-bold text-gray-800 mb-4">운영 원칙</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm text-gray-600">
        <div class="rounded-xl border border-gray-100 bg-gray-50 p-4">
          <h3 class="font-semibold text-gray-800 mb-2">1. 계산은 빠르게</h3>
          <p>복잡한 절차 없이 핵심 입력값만 넣으면 바로 결과를 확인할 수 있게 설계합니다.</p>
        </div>
        <div class="rounded-xl border border-gray-100 bg-gray-50 p-4">
          <h3 class="font-semibold text-gray-800 mb-2">2. 기준은 공개적으로</h3>
          <p>세율, 보험료율, 공식, 가정값은 가능한 한 페이지 안이나 방법론 페이지에서 설명합니다.</p>
        </div>
        <div class="rounded-xl border border-gray-100 bg-gray-50 p-4">
          <h3 class="font-semibold text-gray-800 mb-2">3. 광고보다 사용성 우선</h3>
          <p>광고가 있더라도 핵심 계산과 결과 확인을 방해하지 않는 배치를 우선합니다.</p>
        </div>
        <div class="rounded-xl border border-gray-100 bg-gray-50 p-4">
          <h3 class="font-semibold text-gray-800 mb-2">4. 계산기별 맥락 제공</h3>
          <p>주요 계산기에는 가이드 글, FAQ, 관련 도구 링크를 붙여 결과 해석까지 돕습니다.</p>
        </div>
      </div>
    </section>

    <section class="card">
      <h2 class="text-xl font-bold text-gray-800 mb-4">우선 강화하는 계산기</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        {flagshipCalculators.map((calculator) => (
          <a href={calculator.path} class="rounded-xl border border-gray-200 p-4 hover:border-primary-300 hover:bg-primary-50 transition-colors">
            <div class="flex items-center gap-3">
              <span class="text-2xl" aria-hidden="true">{calculator.icon}</span>
              <div>
                <p class="font-semibold text-gray-800">{calculator.name}</p>
                <p class="text-sm text-gray-500">{calculator.description}</p>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>

    <section class="card">
      <h2 class="text-xl font-bold text-gray-800 mb-4">신뢰 정보</h2>
      <div class="space-y-3 text-sm text-gray-600">
        <p>
          계산 기준, 데이터 출처, 업데이트 원칙은 <a href="/methodology" class="text-primary-600 font-semibold hover:underline">방법론 페이지</a>에서 정리합니다.
        </p>
        <p>
          정책, 오류 제보, 제휴 문의는 <a href="/contact" class="text-primary-600 font-semibold hover:underline">문의 페이지</a> 또는
          <a href={`mailto:${siteMeta.contactEmail}`} class="text-primary-600 font-semibold hover:underline"> {siteMeta.contactEmail}</a>로 받을 수 있습니다.
        </p>
        <p>
          개인정보 처리와 서비스 이용 기준은 <a href="/privacy" class="text-primary-600 font-semibold hover:underline">개인정보처리방침</a>,
          <a href="/terms" class="text-primary-600 font-semibold hover:underline"> 이용약관</a>에 따릅니다.
        </p>
      </div>
    </section>
  </div>
</BaseLayout>

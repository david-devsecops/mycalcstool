---
import SEOHead from '../components/SEOHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  keywords?: string;
  canonicalUrl?: string;
  publishDate: string;
  modifiedDate?: string;
  author?: string;
  category?: string;
  readTime?: string;
  jsonLd?: object | object[];
}

const {
  title,
  description,
  keywords,
  canonicalUrl,
  publishDate,
  modifiedDate,
  author = 'mycalcstool',
  category,
  readTime,
  jsonLd,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <SEOHead
    title={title}
    description={description}
    keywords={keywords}
    canonicalUrl={canonicalUrl}
    lang="en"
    jsonLd={jsonLd}
  />
  <!-- Google Analytics -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-DWJ06N3894"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-DWJ06N3894');
  </script>
  <!-- Google AdSense -->
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-2898972256894696" crossorigin="anonymous"></script>
  <style>
    /* Article content wrapper */
    .blog-article {
      max-width: 720px;
      margin: 0 auto;
    }

    /* Prose base */
    .prose p {
      line-height: 1.8;
      margin-bottom: 1.5rem;
      color: #374151;
    }

    /* Headings */
    .prose h2 {
      font-size: 1.75rem;
      font-weight: 700;
      margin-top: 2.5rem;
      margin-bottom: 0.75rem;
      padding-bottom: 0.5rem;
      border-bottom: 1px solid #e5e7eb;
      color: #111827;
      line-height: 1.3;
    }
    .prose h3 {
      font-size: 1.25rem;
      font-weight: 600;
      margin-top: 2rem;
      margin-bottom: 0.6rem;
      color: #1f2937;
      line-height: 1.4;
    }

    /* Lists */
    .prose ul {
      list-style: disc;
      padding-left: 1.5rem;
      margin-bottom: 1.5rem;
      color: #374151;
    }
    .prose ol {
      list-style: decimal;
      padding-left: 1.5rem;
      margin-bottom: 1.5rem;
      color: #374151;
    }
    .prose li {
      line-height: 1.8;
      margin-bottom: 0.4rem;
    }

    /* Strong */
    .prose strong {
      font-weight: 700;
      color: #111827;
    }

    /* Table */
    .prose .table-wrap {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      margin-bottom: 1.5rem;
      border-radius: 8px;
      border: 1px solid #e5e7eb;
    }
    .prose table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.9rem;
      min-width: 480px;
    }
    .prose thead tr {
      background-color: #f3f4f6;
    }
    .prose th {
      padding: 12px 16px;
      text-align: left;
      font-weight: 600;
      color: #374151;
      white-space: nowrap;
    }
    .prose td {
      padding: 12px 16px;
      color: #374151;
      border-top: 1px solid #e5e7eb;
    }
    .prose tbody tr:nth-child(even) {
      background-color: #f9fafb;
    }

    /* Blockquote */
    .prose blockquote {
      border-left: 4px solid #2563eb;
      background-color: #eff6ff;
      padding: 16px 20px;
      border-radius: 0 8px 8px 0;
      margin: 1.5rem 0;
    }
    .prose blockquote p {
      margin-bottom: 0.5rem;
      color: #1e40af;
      line-height: 1.7;
    }
    .prose blockquote p:last-child {
      margin-bottom: 0;
    }

    /* Links */
    .prose a {
      color: #2563eb;
      text-decoration: underline;
      text-underline-offset: 2px;
    }
    .prose a:hover {
      color: #1d4ed8;
    }

    /* HR */
    .prose hr {
      border: none;
      border-top: 1px solid #e5e7eb;
      margin: 2.5rem 0;
    }

    /* Italic */
    .prose em {
      font-style: italic;
      color: #6b7280;
      font-size: 0.9rem;
    }
  </style>
</head>
<body class="min-h-screen flex flex-col bg-gray-50">
  <Header />
  <main class="flex-1 w-full px-4 py-8" id="main-content">
    <div class="blog-article">
      <!-- Breadcrumb -->
      <nav class="text-sm text-gray-500 mb-4" aria-label="breadcrumb">
        <ol class="flex items-center gap-1 list-none p-0 flex-wrap">
          <li><a href="/en/" class="hover:text-blue-600 transition-colors">Home</a></li>
          <li aria-hidden="true" class="text-gray-300">/</li>
          <li><a href="/en/blog/" class="hover:text-blue-600 transition-colors">Blog</a></li>
          {category && (
            <>
              <li aria-hidden="true" class="text-gray-300">/</li>
              <li class="text-gray-500">{category}</li>
            </>
          )}
        </ol>
      </nav>

      <!-- Article header -->
      <header class="mb-8">
        <h1 class="text-2xl md:text-3xl font-bold text-gray-900 leading-tight mb-4">
          <slot name="headline" />
        </h1>
        <div class="flex items-center gap-3 text-sm text-gray-500 flex-wrap">
          <span>By {author}</span>
          <span aria-hidden="true">·</span>
          <time datetime={publishDate}>
            {new Date(publishDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
          {modifiedDate && (
            <>
              <span aria-hidden="true">·</span>
              <span>Updated <time datetime={modifiedDate}>{new Date(modifiedDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time></span>
            </>
          )}
          {readTime && (
            <>
              <span aria-hidden="true">·</span>
              <span class="flex items-center gap-1">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                {readTime}
              </span>
            </>
          )}
        </div>
      </header>

      <article class="prose">
        <slot />
      </article>
    </div>
  </main>
  <Footer />
</body>
</html>

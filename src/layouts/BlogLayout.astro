---
import SEOHead from '../components/SEOHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AdSlot from '../components/AdSlot.astro';
import MonetizationHead from '../components/MonetizationHead.astro';
import MonetizationRuntime from '../components/MonetizationRuntime.astro';
import { getRelatedEnglishBlogPosts } from '../data/en-blog-posts';
import { siteMeta } from '../data/site-meta';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  keywords?: string;
  canonicalUrl?: string;
  publishDate: string;
  modifiedDate?: string;
  author?: string;
  category?: string;
  readTime?: string;
  jsonLd?: object | object[];
  lang?: 'ko' | 'en';
  homeHref?: string;
  blogHref?: string;
  blogLabel?: string;
  updatedLabel?: string;
  authorPrefix?: string;
  hreflangKo?: string;
  hreflangEn?: string;
}

const {
  title,
  description,
  keywords,
  canonicalUrl,
  publishDate,
  modifiedDate,
  author = siteMeta.editorLabel,
  category,
  readTime,
  jsonLd,
  lang = 'en',
  homeHref = '/en/',
  blogHref = '/en/blog/',
  blogLabel = 'Blog',
  updatedLabel = 'Updated',
  authorPrefix = 'By',
  hreflangKo,
  hreflangEn,
} = Astro.props;

const articlePath = (() => {
  if (canonicalUrl) {
    try {
      return new URL(canonicalUrl).pathname;
    } catch {
      return Astro.url.pathname;
    }
  }

  return Astro.url.pathname;
})();
const pathSegments = articlePath.split('/').filter(Boolean);
const currentSlug = pathSegments[pathSegments.length - 1] ?? '';
const relatedPosts = lang === 'en' ? getRelatedEnglishBlogPosts(currentSlug) : [];
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <MonetizationHead />
  <meta name="color-scheme" content="light" />
  <SEOHead
    title={title}
    description={description}
    keywords={keywords}
    canonicalUrl={canonicalUrl}
    lang={lang}
    jsonLd={jsonLd}
    hreflangKo={hreflangKo}
    hreflangEn={hreflangEn}
  />
  <style>
    /* Article content wrapper */
    .blog-article {
      max-width: 720px;
      margin: 0 auto;
    }

    :root {
      color-scheme: light;
    }

    body.blog-page,
    body.blog-page header,
    body.blog-page #mobile-menu,
    body.blog-page footer {
      background-color: #ffffff !important;
    }

    body.blog-page,
    body.blog-page main {
      color: #111827 !important;
    }

    /* 블로그 본문 컨테이너 */
    .blog-content {
      max-width: 680px;
      margin: 0 auto;
      padding: 0 1.5rem;
      font-size: 1.075rem;
      line-height: 1.9;
      color: #374151 !important;
    }

    /* 문단 간격 */
    .blog-content p {
      color: #374151 !important;
      opacity: 1 !important;
      margin-bottom: 1.5rem;
    }

    /* H2 - 섹션 제목 */
    .blog-content h2 {
      font-size: 1.625rem;
      font-weight: 700;
      margin-top: 3.5rem;
      margin-bottom: 1rem;
      padding-bottom: 0.75rem;
      border-bottom: 2px solid #e5e7eb;
      color: #111827 !important;
    }

    /* H3 - 서브 제목 */
    .blog-content h3 {
      font-size: 1.25rem;
      font-weight: 600;
      margin-top: 2.5rem;
      margin-bottom: 0.75rem;
      color: #1f2937 !important;
    }

    /* H4 */
    .blog-content h4 {
      font-size: 1.1rem;
      font-weight: 600;
      margin-top: 2rem;
      margin-bottom: 0.5rem;
      color: #374151 !important;
    }

    /* 테이블 */
    .blog-content table {
      width: 100%;
      border-collapse: separate;
      border-spacing: 0;
      margin: 1.5rem 0;
      border-radius: 8px;
      overflow: hidden;
      border: 1px solid #e5e7eb;
      font-size: 0.925rem;
    }

    .blog-content thead th {
      background-color: #f9fafb;
      padding: 0.75rem 1rem;
      text-align: left;
      font-weight: 600;
      color: #374151 !important;
      border-bottom: 2px solid #e5e7eb;
    }

    .blog-content tbody td {
      padding: 0.75rem 1rem;
      border-bottom: 1px solid #f3f4f6;
    }

    .blog-content tbody tr:last-child td {
      border-bottom: none;
    }

    .blog-content tbody tr:nth-child(even) {
      background-color: #f9fafb;
    }

    /* 모바일 테이블 가로 스크롤 */
    @media (max-width: 640px) {
      .blog-content table {
        display: block;
        overflow-x: auto;
        white-space: nowrap;
      }
    }

    /* Blockquote - CTA 블록 */
    .blog-content blockquote {
      background: linear-gradient(135deg, #eff6ff, #f0f9ff);
      border-left: 4px solid #3b82f6;
      border-radius: 0 8px 8px 0;
      padding: 1.25rem 1.5rem;
      margin: 2rem 0;
      font-size: 1rem;
    }

    .blog-content blockquote p {
      margin-bottom: 0.5rem;
    }

    .blog-content blockquote a {
      color: #2563eb;
      font-weight: 600;
      text-decoration: underline;
      text-underline-offset: 2px;
    }

    .blog-content blockquote a:hover {
      color: #1d4ed8;
    }

    /* 링크 스타일 */
    .blog-content a {
      color: #2563eb;
      text-decoration: underline;
      text-underline-offset: 2px;
      text-decoration-color: #93c5fd;
      transition: text-decoration-color 0.2s;
    }

    .blog-content a:hover {
      text-decoration-color: #2563eb;
    }

    /* 리스트 */
    .blog-content ul, .blog-content ol {
      margin: 1rem 0 1.5rem 1.5rem;
      line-height: 1.8;
    }

    .blog-content ul {
      list-style: disc;
    }

    .blog-content ol {
      list-style: decimal;
    }

    .blog-content li {
      margin-bottom: 0.5rem;
    }

    /* 구분선 */
    .blog-content hr {
      border: none;
      border-top: 1px solid #e5e7eb;
      margin: 3rem 0;
    }

    /* 볼드 텍스트 강조 */
    .blog-content strong {
      color: #111827 !important;
      font-weight: 600;
    }

    /* 인라인 코드 */
    .blog-content code {
      background-color: #f3f4f6;
      padding: 0.15rem 0.4rem;
      border-radius: 4px;
      font-size: 0.9em;
    }

    /* 이미지 */
    .blog-content img {
      max-width: 100%;
      border-radius: 8px;
      margin: 1.5rem 0;
    }

    /* 글 하단 면책 조항 */
    .blog-content em {
      font-size: 0.875rem;
      color: #6b7280 !important;
      line-height: 1.6;
    }
  </style>
</head>
<body class="min-h-screen flex flex-col bg-gray-50 blog-page">
  <Header />
  <main class="flex-1 w-full px-4 py-8" id="main-content">
    <div class="blog-article">
      <!-- Breadcrumb -->
      <nav class="text-sm text-gray-500 mb-4" aria-label="breadcrumb">
        <ol class="flex items-center gap-1 list-none p-0 flex-wrap">
          <li><a href={homeHref} class="hover:text-blue-600 transition-colors">{lang === 'ko' ? '홈' : 'Home'}</a></li>
          <li aria-hidden="true" class="text-gray-300">/</li>
          <li><a href={blogHref} class="hover:text-blue-600 transition-colors">{blogLabel}</a></li>
          {category && (
            <>
              <li aria-hidden="true" class="text-gray-300">/</li>
              <li class="text-gray-500">{category}</li>
            </>
          )}
        </ol>
      </nav>

      <!-- Article header -->
      <header class="mb-8">
        <h1 class="text-2xl md:text-3xl font-bold text-gray-900 leading-tight mb-4">
          <slot name="headline" />
        </h1>
        <div class="flex items-center gap-3 text-sm text-gray-500 flex-wrap">
          <span>{authorPrefix} {author}</span>
          <span aria-hidden="true">·</span>
          <time datetime={publishDate}>
            {new Date(publishDate).toLocaleDateString(lang === 'ko' ? 'ko-KR' : 'en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
          {modifiedDate && (
            <>
              <span aria-hidden="true">·</span>
              <span>{updatedLabel} <time datetime={modifiedDate}>{new Date(modifiedDate).toLocaleDateString(lang === 'ko' ? 'ko-KR' : 'en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time></span>
            </>
          )}
          {readTime && (
            <>
              <span aria-hidden="true">·</span>
              <span class="flex items-center gap-1">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                {readTime}
              </span>
            </>
          )}
        </div>
      </header>

      <AdSlot slot="top" format="horizontal" />

      <article class="blog-content">
        <slot />
      </article>

      {relatedPosts.length > 0 && (
        <section class="mt-10 pt-8 border-t border-gray-200">
          <div class="flex items-center justify-between gap-3 mb-4 flex-wrap px-6">
            <h2 class="text-xl font-bold text-gray-900">You may also like</h2>
            <a href="/en/blog/" class="text-sm font-semibold text-blue-600 hover:text-blue-700 transition-colors">All articles →</a>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4 px-6">
            {relatedPosts.map((post) => (
              <a href={post.href} class="block rounded-2xl border border-gray-200 bg-white p-5 hover:border-blue-300 hover:shadow-sm transition-all no-underline">
                <div class="flex items-center gap-2 mb-2 flex-wrap">
                  <span class="text-xs font-semibold text-blue-600 bg-blue-50 px-2 py-0.5 rounded-full">{post.category}</span>
                  <span class="text-xs text-gray-400">{post.readTime}</span>
                </div>
                <p class="font-semibold text-gray-900 leading-snug">{post.title}</p>
                <p class="text-sm text-gray-500 mt-2 leading-relaxed">{post.description}</p>
                <p class="text-xs text-gray-400 mt-3">
                  {new Date(post.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                </p>
              </a>
            ))}
          </div>
        </section>
      )}

      <AdSlot slot="content" format="rectangle" />
    </div>
  </main>
  <Footer />
  <MonetizationRuntime />
</body>
</html>

---
import SEOHead from '../components/SEOHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  keywords?: string;
  canonicalUrl?: string;
  publishDate: string;
  modifiedDate?: string;
  author?: string;
  category?: string;
  readTime?: string;
  jsonLd?: object | object[];
}

const {
  title,
  description,
  keywords,
  canonicalUrl,
  publishDate,
  modifiedDate,
  author = 'mycalcstool',
  category,
  readTime,
  jsonLd,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <SEOHead
    title={title}
    description={description}
    keywords={keywords}
    canonicalUrl={canonicalUrl}
    lang="en"
    jsonLd={jsonLd}
  />
  <!-- Google Analytics -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-DWJ06N3894"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-DWJ06N3894');
  </script>
  <!-- Google AdSense -->
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-2898972256894696" crossorigin="anonymous"></script>
  <style>
    /* Article content wrapper */
    .blog-article {
      max-width: 720px;
      margin: 0 auto;
    }

    /* 블로그 본문 컨테이너 */
    .blog-content {
      max-width: 680px;
      margin: 0 auto;
      padding: 0 1.5rem;
      font-size: 1.075rem;
      line-height: 1.9;
      color: #374151;
    }

    /* 문단 간격 */
    .blog-content p {
      margin-bottom: 1.5rem;
    }

    /* H2 - 섹션 제목 */
    .blog-content h2 {
      font-size: 1.625rem;
      font-weight: 700;
      margin-top: 3.5rem;
      margin-bottom: 1rem;
      padding-bottom: 0.75rem;
      border-bottom: 2px solid #e5e7eb;
      color: #111827;
    }

    /* H3 - 서브 제목 */
    .blog-content h3 {
      font-size: 1.25rem;
      font-weight: 600;
      margin-top: 2.5rem;
      margin-bottom: 0.75rem;
      color: #1f2937;
    }

    /* H4 */
    .blog-content h4 {
      font-size: 1.1rem;
      font-weight: 600;
      margin-top: 2rem;
      margin-bottom: 0.5rem;
      color: #374151;
    }

    /* 테이블 */
    .blog-content table {
      width: 100%;
      border-collapse: separate;
      border-spacing: 0;
      margin: 1.5rem 0;
      border-radius: 8px;
      overflow: hidden;
      border: 1px solid #e5e7eb;
      font-size: 0.925rem;
    }

    .blog-content thead th {
      background-color: #f9fafb;
      padding: 0.75rem 1rem;
      text-align: left;
      font-weight: 600;
      color: #374151;
      border-bottom: 2px solid #e5e7eb;
    }

    .blog-content tbody td {
      padding: 0.75rem 1rem;
      border-bottom: 1px solid #f3f4f6;
    }

    .blog-content tbody tr:last-child td {
      border-bottom: none;
    }

    .blog-content tbody tr:nth-child(even) {
      background-color: #f9fafb;
    }

    /* 모바일 테이블 가로 스크롤 */
    @media (max-width: 640px) {
      .blog-content table {
        display: block;
        overflow-x: auto;
        white-space: nowrap;
      }
    }

    /* Blockquote - CTA 블록 */
    .blog-content blockquote {
      background: linear-gradient(135deg, #eff6ff, #f0f9ff);
      border-left: 4px solid #3b82f6;
      border-radius: 0 8px 8px 0;
      padding: 1.25rem 1.5rem;
      margin: 2rem 0;
      font-size: 1rem;
    }

    .blog-content blockquote p {
      margin-bottom: 0.5rem;
    }

    .blog-content blockquote a {
      color: #2563eb;
      font-weight: 600;
      text-decoration: underline;
      text-underline-offset: 2px;
    }

    .blog-content blockquote a:hover {
      color: #1d4ed8;
    }

    /* 링크 스타일 */
    .blog-content a {
      color: #2563eb;
      text-decoration: underline;
      text-underline-offset: 2px;
      text-decoration-color: #93c5fd;
      transition: text-decoration-color 0.2s;
    }

    .blog-content a:hover {
      text-decoration-color: #2563eb;
    }

    /* 리스트 */
    .blog-content ul, .blog-content ol {
      margin: 1rem 0 1.5rem 1.5rem;
      line-height: 1.8;
    }

    .blog-content ul {
      list-style: disc;
    }

    .blog-content ol {
      list-style: decimal;
    }

    .blog-content li {
      margin-bottom: 0.5rem;
    }

    /* 구분선 */
    .blog-content hr {
      border: none;
      border-top: 1px solid #e5e7eb;
      margin: 3rem 0;
    }

    /* 볼드 텍스트 강조 */
    .blog-content strong {
      color: #111827;
      font-weight: 600;
    }

    /* 인라인 코드 */
    .blog-content code {
      background-color: #f3f4f6;
      padding: 0.15rem 0.4rem;
      border-radius: 4px;
      font-size: 0.9em;
    }

    /* 이미지 */
    .blog-content img {
      max-width: 100%;
      border-radius: 8px;
      margin: 1.5rem 0;
    }

    /* 글 하단 면책 조항 */
    .blog-content em {
      font-size: 0.875rem;
      color: #6b7280;
      line-height: 1.6;
    }

    /* 다크모드 지원 */
    @media (prefers-color-scheme: dark) {
      .blog-content {
        color: #d1d5db;
      }
      .blog-content h2 {
        color: #f9fafb;
        border-bottom-color: #374151;
      }
      .blog-content h3, .blog-content h4 {
        color: #e5e7eb;
      }
      .blog-content strong {
        color: #f9fafb;
      }
      .blog-content blockquote {
        background: linear-gradient(135deg, #1e293b, #1e3a5f);
        border-left-color: #60a5fa;
      }
      .blog-content blockquote a {
        color: #60a5fa;
      }
      .blog-content thead th {
        background-color: #1f2937;
        border-bottom-color: #374151;
      }
      .blog-content tbody tr:nth-child(even) {
        background-color: #1f2937;
      }
      .blog-content tbody td {
        border-bottom-color: #374151;
      }
      .blog-content table {
        border-color: #374151;
      }
      .blog-content hr {
        border-top-color: #374151;
      }
      .blog-content code {
        background-color: #1f2937;
      }
      .blog-content em {
        color: #9ca3af;
      }
    }
  </style>
</head>
<body class="min-h-screen flex flex-col bg-gray-50">
  <Header />
  <main class="flex-1 w-full px-4 py-8" id="main-content">
    <div class="blog-article">
      <!-- Breadcrumb -->
      <nav class="text-sm text-gray-500 mb-4" aria-label="breadcrumb">
        <ol class="flex items-center gap-1 list-none p-0 flex-wrap">
          <li><a href="/en/" class="hover:text-blue-600 transition-colors">Home</a></li>
          <li aria-hidden="true" class="text-gray-300">/</li>
          <li><a href="/en/blog/" class="hover:text-blue-600 transition-colors">Blog</a></li>
          {category && (
            <>
              <li aria-hidden="true" class="text-gray-300">/</li>
              <li class="text-gray-500">{category}</li>
            </>
          )}
        </ol>
      </nav>

      <!-- Article header -->
      <header class="mb-8">
        <h1 class="text-2xl md:text-3xl font-bold text-gray-900 leading-tight mb-4">
          <slot name="headline" />
        </h1>
        <div class="flex items-center gap-3 text-sm text-gray-500 flex-wrap">
          <span>By {author}</span>
          <span aria-hidden="true">·</span>
          <time datetime={publishDate}>
            {new Date(publishDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
          {modifiedDate && (
            <>
              <span aria-hidden="true">·</span>
              <span>Updated <time datetime={modifiedDate}>{new Date(modifiedDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time></span>
            </>
          )}
          {readTime && (
            <>
              <span aria-hidden="true">·</span>
              <span class="flex items-center gap-1">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                {readTime}
              </span>
            </>
          )}
        </div>
      </header>

      <article class="blog-content">
        <slot />
      </article>
    </div>
  </main>
  <Footer />
</body>
</html>
